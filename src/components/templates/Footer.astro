---
import { FOOTER_LINKS, SITE } from "../../lib/constants";
import Container from "../atoms/Container.astro";
---

<footer class="border-t border-border bg-bg-secondary/80">
  <Container>
    <div class="py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-lg font-semibold text-text-primary mb-3">{SITE.author}</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          {SITE.description}
        </p>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-text-primary mb-3">Links</h4>
        <ul class="space-y-2">
          {
            FOOTER_LINKS.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-text-secondary hover:text-brand transition-colors">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-text-primary mb-3">Connect</h4>
        <ul class="space-y-2">
          <li>
            <a href={SITE.github} class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-brand transition-colors" target="_blank" rel="noopener noreferrer">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" /><path d="M9 18c-4.51 2-5-2-7-2" /></svg>
              GitHub
              <span class="sr-only">(opens in new tab)</span>
            </a>
          </li>
          <li>
            <a href={SITE.linkedin} class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-brand transition-colors" target="_blank" rel="noopener noreferrer">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" /><rect x="2" y="9" width="4" height="12" /><circle cx="4" cy="4" r="2" /></svg>
              LinkedIn
              <span class="sr-only">(opens in new tab)</span>
            </a>
          </li>
          <li>
            <a href="/contact" class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-brand transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" /><path d="M22 7l-10 7L2 7" /></svg>
              Contact
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="py-6 border-t border-border text-center">
      <p class="text-xs text-text-secondary/40">
        &copy; {new Date().getFullYear()} {SITE.author} &middot; Built with Astro
      </p>
    </div>
  </Container>
</footer>
