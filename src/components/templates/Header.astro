---
export interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
import ThemeCustomizer from "../../islands/ThemeCustomizer";
import Container from "../atoms/Container.astro";
import ThemeToggle from "../atoms/ThemeToggle.astro";
import { GameMenuWrapper } from "../game-menu/GameMenuWrapper";

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/#experience", label: "Experience" },
  { href: "/#projects", label: "Projects" },
  { href: "/#skills", label: "Skills" },
  { href: "/#contact", label: "Contact" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/80 backdrop-blur-md border-b border-border" role="banner">
  <Container>
    <nav class="flex items-center justify-between h-16" aria-label="Primary">
      <a href="/" class="text-xl font-bold text-text-primary hover:text-brand transition-colors" aria-label="Home">
        AMERTA
      </a>
      <ul class="hidden md:flex items-center gap-6 list-none">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-text-secondary hover:text-brand transition-colors"
                aria-current={currentPath === link.href ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="flex items-center gap-2">
        <ThemeCustomizer client:load />
        <GameMenuWrapper client:load />
        <div class="w-px h-5 bg-border mx-1"></div>
        <ThemeToggle />
      </div>
    </nav>
  </Container>
</header>
