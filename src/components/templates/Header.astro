---
export interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
import Container from "../atoms/Container.astro";
import ThemeToggle from "../atoms/ThemeToggle.astro";
import { GameMenuWrapper } from "../game-menu/GameMenuWrapper";
import { GameModeToggle } from "../game-menu/GameModeToggle";
---

<header class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/80 backdrop-blur-md border-b border-accent/10">
  <Container>
    <nav class="flex items-center justify-between h-16" aria-label="Primary">
      <a href="/" class="text-xl font-black text-accent hover:text-accent/80 transition-colors uppercase tracking-widest" aria-label="Home" style="transform: skewX(-8deg);">
        <span class="flex items-center gap-2">
          <span class="w-2 h-2 bg-accent inline-block pulse-ring" />
          AMERTA
        </span>
      </a>
      <div class="flex items-center gap-2">
        <GameModeToggle client:load />
        <GameMenuWrapper client:load />
        <div class="w-px h-5 bg-accent/20 mx-1"></div>
        <ThemeToggle />
      </div>
    </nav>
  </Container>
</header>
