---
export interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
import { NAV_ITEMS } from "../../lib/constants";
import Container from "../ui/Container.astro";
import ThemeToggle from "../ui/ThemeToggle.astro";
---

<header class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/80 backdrop-blur-md border-b border-border">
  <Container>
    <nav class="flex items-center justify-between h-16" aria-label="Primary">
      <a href="/" class="text-xl font-bold text-accent hover:text-accent/90 transition-colors" aria-label="Home">
        AM
      </a>
      <div class="flex items-center gap-1">
        {
          NAV_ITEMS.map((item) => {
            const isCurrent = currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href));
            return (
              <a
                href={item.href}
                class:list={[
                  "px-3 py-2 text-sm rounded-lg transition-all duration-200",
                  isCurrent
                    ? "text-accent bg-accent-muted/15"
                    : "text-text-secondary hover:text-text-primary hover:bg-bg-tertiary",
                ]}
                aria-current={isCurrent ? "page" : undefined}
              >
                {item.label}
              </a>
            );
          })
        }
        <ThemeToggle />
      </div>
    </nav>
  </Container>
</header>
