---
import ImpactMetrics from "../../islands/ImpactMetrics";
import type { Profile } from "../../types/profile";

export interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
const { metrics } = profile;

const metricItems = [
  {
    label: "Years Experience",
    value: metrics.years_experience,
    suffix: "+",
    context: "In AI/ML and software engineering",
  },
  {
    label: "Projects Shipped",
    value: metrics.projects_shipped,
    suffix: "+",
    context: "From concept to production",
  },
  {
    label: "Certifications",
    value: metrics.certifications,
    suffix: "",
    context: "Across cloud, ML, and systems",
  },
  {
    label: "Languages",
    value: metrics.languages.length,
    suffix: "",
    context: "Programming & spoken languages",
  },
];
---

<div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl">
    <p class="text-text-primary leading-relaxed text-lg">
      {profile.summary}
    </p>
    <div class="flex items-center gap-3 mt-6">
      <span class="inline-flex items-center gap-1.5 text-sm text-text-secondary">
        <span class="w-1.5 h-1.5 rounded-full bg-brand/60" />
        {profile.location}
      </span>
      <span class="text-text-secondary/30">·</span>
      <span class="text-sm text-text-secondary">{profile.timezone}</span>
    </div>
  </div>
  <div class="mt-8">
    <ImpactMetrics client:idle metrics={metricItems} />
  </div>
</div>
