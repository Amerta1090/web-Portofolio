---
import MetricsCounter from "../../islands/MetricsCounter";
import type { Profile } from "../../types/profile";

export interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
const { metrics } = profile;

const metricItems = [
  { label: "Years Experience", value: metrics.years_experience, suffix: "+" },
  { label: "Projects Shipped", value: metrics.projects_shipped, suffix: "+" },
  { label: "Certifications", value: metrics.certifications, suffix: "" },
  { label: "Languages", value: metrics.languages.length, suffix: "" },
];
---

<div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8">
  <div class="grid md:grid-cols-5 gap-8 md:gap-12 items-start">
    <div class="md:col-span-3">
      <div class="border-l-4 border-accent pl-6">
  <p class="text-text-primary leading-relaxed text-lg">
    {profile.summary}
  </p>
  <div class="flex items-center gap-3 mt-4">
    <span class="text-sm text-text-secondary">{profile.location}</span>
    <span class="text-text-secondary/30">·</span>
    <span class="text-sm text-text-secondary">{profile.timezone}</span>
  </div>
      </div>
    </div>
    <div class="md:col-span-2">
      <MetricsCounter client:idle metrics={metricItems} />
    </div>
  </div>
</div>
