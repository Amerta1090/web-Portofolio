---
import { Mail } from "lucide-react";
import type { Profile } from "../../types/profile";
import ContactForm from "../../islands/ContactForm";
import IconGitHub from "../atoms/IconGitHub.astro";
import IconLinkedIn from "../atoms/IconLinkedIn.astro";

export interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
const { contact } = profile;
---

<div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8">
  <div class="grid md:grid-cols-2 gap-8 md:gap-12">
    <div>
      <h3 class="text-lg font-semibold text-text-primary mb-4">Get in Touch</h3>
      <p class="text-text-secondary mb-8 leading-relaxed">
        Have a question, project idea, or just want to connect? Feel free to reach out.
      </p>
      <div class="space-y-3">
        <a
          href={`mailto:${contact.email}`}
          class="flex items-center gap-3 p-3 bg-bg-secondary border border-border rounded-xl hover:border-brand/30 transition-all duration-200 group"
        >
          <div class="w-10 h-10 rounded-lg bg-brand/10 flex items-center justify-center flex-shrink-0">
            <Mail class="w-5 h-5 text-brand" aria-hidden="true" />
          </div>
          <div>
            <p class="text-sm font-medium text-text-primary group-hover:text-brand transition-colors">Email</p>
            <p class="text-sm text-text-secondary">{contact.email}</p>
          </div>
        </a>
        <a
          href={contact.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 p-3 bg-bg-secondary border border-border rounded-xl hover:border-brand/30 transition-all duration-200 group"
        >
          <div class="w-10 h-10 rounded-lg bg-brand/10 flex items-center justify-center flex-shrink-0">
            <IconLinkedIn size={20} class="text-brand" />
          </div>
          <div>
            <p class="text-sm font-medium text-text-primary group-hover:text-brand transition-colors">LinkedIn</p>
            <p class="text-sm text-text-secondary">Abdul Majid Ridwan Tyastonoatmaja</p>
          </div>
        </a>
        <a
          href={contact.github}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 p-3 bg-bg-secondary border border-border rounded-xl hover:border-brand/30 transition-all duration-200 group"
        >
          <div class="w-10 h-10 rounded-lg bg-brand/10 flex items-center justify-center flex-shrink-0">
            <IconGitHub size={20} class="text-brand" />
          </div>
          <div>
            <p class="text-sm font-medium text-text-primary group-hover:text-brand transition-colors">GitHub</p>
            <p class="text-sm text-text-secondary">Amerta1090</p>
          </div>
        </a>
      </div>
    </div>
    <div>
      <h3 class="text-lg font-semibold text-text-primary mb-4">Send a Message</h3>
      <ContactForm client:load />
    </div>
  </div>
</div>
