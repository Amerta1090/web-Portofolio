---
import type { Certification } from "../../types/certifications";

export interface Props {
  certifications: Certification[];
}

const { certifications } = Astro.props;

function formatDate(date: string | null): string {
  if (!date) return "";
  const [year, month] = date.split("-");
  const months = [
    "Jan",
    "Feb",
    "Mar",
    "Apr",
    "May",
    "Jun",
    "Jul",
    "Aug",
    "Sep",
    "Oct",
    "Nov",
    "Dec",
  ];
  return month ? `${months[Number.parseInt(month) - 1]} ${year}` : year;
}

const grouped = certifications.reduce((acc: Record<string, Certification[]>, cert) => {
  const issuer = cert.issuer || "Other";
  if (!acc[issuer]) acc[issuer] = [];
  acc[issuer].push(cert);
  return acc;
}, {});
---

<div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8">
  <div class="mb-6">
    <span class="text-xs text-text-secondary border border-border px-2 py-1 rounded">
      {certifications.length} Certifications
    </span>
  </div>
  <div class="space-y-3">
    {
      Object.entries(grouped).map(([issuer, certs]) => (
        <details class="group bg-bg-secondary/50 border border-border rounded-lg overflow-hidden">
          <summary class="flex items-center justify-between p-4 cursor-pointer hover:bg-brand/5 transition-colors list-none rounded-lg">
            <div class="flex items-center gap-3">
              <h3 class="font-semibold text-text-primary text-sm">{issuer}</h3>
              <span class="text-[10px] text-text-secondary/60 border border-border px-1.5 py-0.5 rounded">{certs.length}</span>
            </div>
            <svg
              class="w-5 h-5 text-text-secondary group-open:rotate-180 transition-transform duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m6 9 6 6 6-6" />
            </svg>
          </summary>
          <div class="border-t border-border">
            {certs.map((cert) => (
              <div class="p-4 border-b border-border last:border-b-0 hover:bg-brand/5 transition-colors">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="text-text-primary text-sm">
                      {cert.url
                        ? <a href={cert.url} target="_blank" rel="noopener noreferrer" class="hover:text-brand transition-colors">{cert.title}<span class="sr-only"> (opens in new tab)</span></a>
                        : cert.title
                      }
                    </p>
                    {cert.date && (
                      <p class="text-xs text-text-secondary/60 mt-0.5">{formatDate(cert.date)}</p>
                    )}
                  </div>
                  {cert.credential_id && (
                    <span class="text-[10px] text-text-secondary/30 flex-shrink-0">ID: {cert.credential_id}</span>
                  )}
                </div>
                {cert.skills && cert.skills.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 mt-2">
                    {cert.skills.map((skill) => (
                      <span class="text-[9px] px-1.5 py-0.5 border border-border text-text-secondary rounded">{skill}</span>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </details>
      ))
    }
  </div>
  <div class="mt-8 text-center">
    <a href="/certifications" class="inline-flex items-center gap-2 text-sm text-brand hover:text-brand-muted transition-colors group">
      View all {certifications.length} certifications
      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
    </a>
  </div>
</div>
