---
import type { GitHubData } from "../../types/github";

export interface Props {
  data: GitHubData;
}

const { data } = Astro.props;
const topRepos = data.pinned_repos.slice(0, 3);
---

{
  topRepos.length > 0 && (
    <div class="grid md:grid-cols-3 gap-4 mb-8">
      {topRepos.map((repo) => (
        <a
          href={repo.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block bg-bg-secondary/50 border border-accent/10 hover:border-accent/40 transition-all duration-300 p-5"
        >
          <span class="sr-only">View {repo.name} on GitHub (opens in new tab)</span>
          <div class="flex items-center gap-2 mb-2">
            <span class="text-accent text-sm">◆</span>
            <h3 class="font-black text-sm uppercase tracking-wider text-text-primary truncate group-hover:text-accent transition-colors">
              {repo.name}
            </h3>
          </div>
          <p class="text-xs text-text-secondary leading-relaxed line-clamp-2 mb-3 font-mono">
            {repo.description ?? "No description"}
          </p>
          <div class="flex items-center gap-4 text-xs text-text-secondary/60">
            {repo.language && (
              <span class="flex items-center gap-1.5 font-mono">
                <span class="w-1.5 h-1.5 bg-accent" />
                {repo.language}
              </span>
            )}
            <span class="flex items-center gap-1 font-mono">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              {repo.stars}
            </span>
          </div>
        </a>
      ))}
    </div>
  )
}

<div class="flex items-center gap-6 flex-wrap border-t border-accent/10 pt-6">
  <div class="flex items-center gap-2">
    <span class="text-3xl font-black text-accent">{data.contribution_count}</span>
    <span class="text-xs font-mono text-text-secondary/60 uppercase tracking-wider">Contributions</span>
  </div>
  <div class="flex items-center gap-2">
    <span class="text-3xl font-black text-text-primary">{data.total_repos}</span>
    <span class="text-xs font-mono text-text-secondary/60 uppercase tracking-wider">Repositories</span>
  </div>
  <a
    href="/github"
    class="text-xs font-mono text-accent hover:text-accent-muted transition-colors ml-auto uppercase tracking-wider group flex items-center gap-1"
  >
    View all
    <span class="group-hover:translate-x-1 transition-transform">→</span>
  </a>
</div>
