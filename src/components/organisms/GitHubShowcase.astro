---
import { ArrowRight, Star } from "lucide-react";
import type { GitHubData } from "../../types/github";

export interface Props {
  data: GitHubData;
}

const { data } = Astro.props;
const topRepos = data.pinned_repos.slice(0, 3);
---

{
  topRepos.length > 0 && (
    <div class="grid md:grid-cols-3 gap-4 mb-8">
      {topRepos.map((repo) => (
        <a
          href={repo.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group block bg-bg-secondary/50 border border-border hover:border-brand/40 transition-all duration-300 rounded-lg p-5"
        >
          <span class="sr-only">View {repo.name} on GitHub (opens in new tab)</span>
          <div class="flex items-center gap-2 mb-2">
            <h3 class="font-semibold text-sm text-text-primary truncate group-hover:text-brand transition-colors">
              {repo.name}
            </h3>
          </div>
          <p class="text-xs text-text-secondary leading-relaxed line-clamp-2 mb-3">
            {repo.description ?? "No description"}
          </p>
          <div class="flex items-center gap-4 text-xs text-text-secondary/60">
            {repo.language && (
              <span class="flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 bg-brand rounded-full" />
                {repo.language}
              </span>
            )}
            <span class="flex items-center gap-1">
              <Star class="w-3 h-3" aria-hidden="true" />
              {repo.stars}
            </span>
          </div>
        </a>
      ))}
    </div>
  )
}

<div class="flex items-center gap-6 flex-wrap border-t border-border pt-6">
  <div class="flex items-center gap-2">
    <span class="text-3xl font-bold text-brand">{data.contribution_count}</span>
    <span class="text-xs text-text-secondary/60">Contributions</span>
  </div>
  <div class="flex items-center gap-2">
    <span class="text-3xl font-bold text-text-primary">{data.total_repos}</span>
    <span class="text-xs text-text-secondary/60">Repositories</span>
  </div>
  <a
    href="/github"
    class="text-xs text-brand hover:text-brand-muted transition-colors ml-auto group flex items-center gap-1"
  >
    View all
    <ArrowRight class="w-4 h-4 group-hover:translate-x-1 transition-transform" aria-hidden="true" />
  </a>
</div>
