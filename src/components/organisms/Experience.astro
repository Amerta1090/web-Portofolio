---
import type { Experience } from "../../types/experience";

export interface Props {
  experiences: Experience[];
}

const { experiences } = Astro.props;

function formatDate(date: string | null): string {
  if (!date) return "Present";
  const [year, month] = date.split("-");
  const months = [
    "Jan",
    "Feb",
    "Mar",
    "Apr",
    "May",
    "Jun",
    "Jul",
    "Aug",
    "Sep",
    "Oct",
    "Nov",
    "Dec",
  ];
  return month ? `${months[Number.parseInt(month) - 1]} ${year}` : year;
}

const typeColors: Record<string, string> = {
  "full-time": "bg-accent",
  "full-time contract": "bg-accent",
  "part-time": "bg-accent-muted",
  contract: "bg-accent-muted",
  internship: "bg-accent/60",
};
---

<div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8">
  <div class="relative">
    <div class="absolute left-[19px] top-0 bottom-0 w-px bg-accent/20 timeline-line-draw" />
    <div class="space-y-8">
      {
        experiences
          .sort((a, b) => b.start_date.localeCompare(a.start_date))
          .map((exp) => (
            <div class="relative pl-14">
              <div class={`absolute left-[10px] top-2 w-[20px] h-[20px] rounded-full border-2 border-bg-primary ${typeColors[exp.type] || "bg-accent"} z-10 shadow-[0_0_8px_var(--accent-glow)]`} />
              <div class="bg-bg-secondary/80 border border-accent/10 hover:border-accent/30 transition-all duration-300 p-6">
                <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
                  <div>
                    <h3 class="text-xl font-black uppercase tracking-wider text-text-primary">
                      {exp.role}
                    </h3>
                    <div class="flex items-center gap-2 mt-1">
                      <span class="text-accent font-mono text-sm font-bold">{exp.company}</span>
                      {!exp.end_date && (
                        <span class="text-[9px] font-mono text-accent border border-accent/30 px-1.5 py-0.5 uppercase tracking-widest">ACTIVE</span>
                      )}
                    </div>
                  </div>
                  <div class="text-right">
                    <div class="text-xs font-mono text-accent tracking-wider">
                      {formatDate(exp.start_date)} — {formatDate(exp.end_date)}
                    </div>
                    <div class="text-[10px] font-mono text-text-secondary/40 uppercase mt-0.5">
                      {exp.type} {exp.location ? `· ${exp.location}` : ""}
                    </div>
                  </div>
                </div>
                {exp.highlights.length > 0 && (
                  <ul class="space-y-1.5 mb-3">
                    {exp.highlights.map((h) => (
                      <li class="text-text-secondary text-sm flex gap-2">
                        <span class="text-accent mt-1.5 flex-shrink-0 w-1 h-1 bg-accent rounded-full" />
                        <span>{h}</span>
                      </li>
                    ))}
                  </ul>
                )}
                <div class="flex flex-wrap gap-1.5">
                  {exp.technologies.map((tech) => (
                    <span class="text-[10px] font-mono px-2 py-0.5 border border-accent/15 text-accent/70 uppercase tracking-wider">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          ))
      }
    </div>
  </div>
</div>
