---
import type { Honor } from "../../types/honors";
import { Badge } from "../atoms/Badge.tsx";
import Card from "../molecules/Card.astro";

export interface Props {
  honors: Honor[];
}

const { honors } = Astro.props;
---

<div class="grid md:grid-cols-3 gap-6">
  {
    honors.map((honor) => (
      <Card variant="elevated">
        <div class="flex items-start justify-between gap-2 mb-2">
          <h3 class="text-base font-semibold text-text-primary">
            {honor.title}
          </h3>
          <Badge variant={honor.category === "competition" ? "accent" : "default"}>
            {honor.category}
          </Badge>
        </div>
        <p class="text-sm text-text-secondary">{honor.event}</p>
        <p class="text-xs text-text-secondary mt-1">{honor.date}</p>
        {honor.description && (
          <p class="text-sm text-text-secondary mt-2">{honor.description}</p>
        )}
      </Card>
    ))
  }
</div>
