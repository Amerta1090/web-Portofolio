---
import type { Honor } from "../../types/honors";
import { Badge } from "../atoms/Badge.tsx";

export interface Props {
  honors: Honor[];
}

const { honors } = Astro.props;
---

<div class="grid md:grid-cols-3 gap-6">
  {
    honors.map((honor) => (
      <div class="card rounded-lg border border-border bg-surface-primary text-text-primary shadow-md p-6">
        {honor.image && (
          <div class="w-full max-w-[120px] h-[80px] mx-auto mb-4 rounded-xl bg-white shadow-sm border border-border/30 flex items-center justify-center p-3">
            <img
              src={honor.image}
              alt={honor.title}
              class="max-w-full max-h-full object-contain"
              loading="lazy"
              onerror="this.style.display='none'"
            />
          </div>
        )}
        <div class="flex items-start justify-between gap-2 mb-2">
          <h3 class="text-base font-semibold text-text-primary">
            {honor.title}
          </h3>
          <Badge variant={honor.category === "competition" ? "accent" : "default"}>
            {honor.category}
          </Badge>
        </div>
        <p class="text-sm text-text-secondary">{honor.event}</p>
        <p class="text-xs text-text-secondary mt-1">{honor.date}</p>
        {honor.description && (
          <p class="text-sm text-text-secondary mt-2">{honor.description}</p>
        )}
      </div>
    ))
  }
</div>
