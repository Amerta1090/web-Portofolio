---
import type { Volunteering } from "../../types/volunteering";

export interface Props {
  volunteerings: Volunteering[];
}

const { volunteerings } = Astro.props;

function formatDate(date: string | null): string {
  if (!date) return "";
  const [year, month] = date.split("-");
  const months = [
    "Jan",
    "Feb",
    "Mar",
    "Apr",
    "May",
    "Jun",
    "Jul",
    "Aug",
    "Sep",
    "Oct",
    "Nov",
    "Dec",
  ];
  return month ? `${months[Number.parseInt(month) - 1]} ${year}` : year;
}
---

<div class="grid md:grid-cols-2 gap-6">
  {
    volunteerings.map((v) => (
      <div class="rounded-lg border border-border bg-surface-primary text-text-primary shadow-md p-6">
        <h3 class="text-base font-semibold text-text-primary mb-1">{v.role}</h3>
        <p class="text-sm text-text-secondary">{v.organization}</p>
        {v.cause && <p class="text-xs text-text-secondary mt-1">{v.cause}</p>}
        <p class="text-xs text-text-secondary mt-0.5">
          {formatDate(v.start_date)} – {formatDate(v.end_date)}
        </p>
        {v.highlights && v.highlights.length > 0 && (
          <ul class="mt-2 space-y-1">
            {v.highlights.map((h) => (
              <li class="text-sm text-text-secondary flex gap-2">
                <span class="text-brand mt-1.5 flex-shrink-0 w-1.5 h-1.5 rounded-full bg-brand" />
                <span>{h}</span>
              </li>
            ))}
          </ul>
        )}
      </div>
    ))
  }
</div>
