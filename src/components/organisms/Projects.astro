---
import type { Project } from "../../types/project";

export interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

function slugify(title: string): string {
  return title.toLowerCase().replace(/[^a-z0-9]+/g, "-");
}
---

<div class="container-query-grid">
  <div class="cq-grid-item grid gap-5">
    {
      projects.map((project, idx) => (
        <a
          href={`/projects/${slugify(project.title)}`}
          class="card group block bg-bg-secondary border border-border transition-all duration-300 rounded-lg p-6"
        >
          <div class="flex items-start justify-between gap-3 mb-3">
            <div class="flex items-center gap-2">
              <span class="text-xs text-text-secondary">{project.category}</span>
            </div>
            {project.featured && (
              <span class="featured-badge text-[10px] text-brand border border-brand/30 px-1.5 py-0.5 rounded">Featured</span>
            )}
          </div>
          
          <h3 class="text-lg font-semibold text-text-primary group-hover:text-brand transition-colors leading-tight mb-2">
            {project.title}
          </h3>
          
          <p class="text-text-secondary text-sm leading-relaxed line-clamp-2 mb-3">
            {project.description}
          </p>
          
          {project.period && (
            <p class="text-xs text-text-secondary/50 mb-3">{project.period}</p>
          )}
          
          <div class="flex flex-wrap gap-1.5">
            {project.skills.slice(0, 4).map((skill: string) => (
              <span class="text-[10px] px-1.5 py-0.5 border border-border text-text-secondary rounded">
                {skill.length > 15 ? skill.slice(0, 15) + "…" : skill}
              </span>
            ))}
            {project.skills.length > 4 && (
              <span class="text-[10px] px-1.5 py-0.5 border border-border text-text-secondary rounded">+{project.skills.length - 4}</span>
            )}
          </div>
        </a>
      ))
    }
  </div>
</div>
