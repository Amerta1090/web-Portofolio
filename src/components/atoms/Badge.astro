---
export interface Props {
  variant?: "default" | "secondary" | "outline" | "brand";
  class?: string;
}

const { variant = "default", class: className } = Astro.props;

const variants: Record<string, string> = {
  default: "bg-surface-tertiary text-text-secondary",
  secondary: "bg-surface-secondary text-text-primary",
  outline: "text-text-secondary border-border",
  brand: "bg-accent/10 text-accent",
};

const cls = `inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-medium ${variants[variant]} ${className ?? ""}`;
---

<span class={cls}>
  <slot />
</span>
