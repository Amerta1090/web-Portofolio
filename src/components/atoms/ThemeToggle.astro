---
import { Moon, Sun } from "lucide-react";
---

<button
  id="theme-toggle"
  class="theme-rotate inline-flex items-center justify-center w-10 h-10 text-text-secondary hover:text-brand hover:border-brand/40 transition-all duration-200 border border-border focus:outline-none focus-visible:ring-2 focus-visible:ring-brand"
  aria-label="Toggle theme"
  aria-live="polite"
  data-theme-toggle
>
  <Sun class="dark:hidden w-5 h-5" aria-hidden="true" />
  <Moon class="hidden dark:block w-5 h-5" aria-hidden="true" />
</button>

<script is:inline>
  (function () {
    const btn = document.querySelector("[data-theme-toggle]");
    if (!btn) return;
    const isDark = document.documentElement.classList.contains("dark");
    btn.setAttribute("aria-label", isDark ? "Switch to light mode" : "Switch to dark mode");
    btn.addEventListener("click", function () {
      var html = document.documentElement;
      var isDark = html.classList.contains("dark");
      if (isDark) {
        html.classList.remove("dark");
        btn.setAttribute("aria-label", "Switch to dark mode");
      } else {
        html.classList.add("dark");
        btn.setAttribute("aria-label", "Switch to light mode");
      }
      var next = isDark ? "light" : "dark";
      localStorage.setItem("theme-mode", next);
      try {
        localStorage.setItem("theme", JSON.stringify({ state: { theme: next }, version: 0 }));
      } catch (e) {}
    });
  })();
</script>
