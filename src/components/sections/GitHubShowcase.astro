---
import type { GitHubData } from "../../types/github";

export interface Props {
  data: GitHubData;
}

const { data } = Astro.props;
const topRepos = data.pinned_repos.slice(0, 3);
---

{
  topRepos.length > 0 && (
    <div class="grid md:grid-cols-3 gap-4 mb-8">
      {topRepos.map((repo) => (
        <a
          href={repo.url}
          target="_blank"
          rel="noopener noreferrer"
          class="block bg-bg-secondary border border-border rounded-xl p-4 hover:border-accent/30 hover:-translate-y-0.5 transition-all duration-200"
        >
          <span class="sr-only">View {repo.name} on GitHub (opens in new tab)</span>
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-4 h-4 text-text-secondary shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
            <h3 class="font-medium text-text-primary text-sm truncate">{repo.name}</h3>
          </div>
          <p class="text-xs text-text-secondary line-clamp-2 mb-3">
            {repo.description ?? "No description"}
          </p>
          <div class="flex items-center gap-3 text-xs text-text-secondary">
            {repo.language && (
              <span class="flex items-center gap-1">
                <span class="w-2 h-2 rounded-full bg-accent" />
                {repo.language}
              </span>
            )}
            <span class="flex items-center gap-1">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              {repo.stars}
            </span>
          </div>
        </a>
      ))}
    </div>
  )
}

<div class="flex items-center gap-6 flex-wrap">
  <div class="flex items-center gap-2 text-sm text-text-secondary">
    <span class="text-2xl font-bold text-accent">{data.contribution_count}</span>
    contributions this year
  </div>
  <div class="flex items-center gap-2 text-sm text-text-secondary">
    <span class="text-2xl font-bold text-text-primary">{data.total_repos}</span>
    repositories
  </div>
  <a
    href="/github"
    class="text-sm text-accent hover:text-accent/80 transition-colors font-medium ml-auto"
  >
    View all on GitHub &rarr;
  </a>
</div>
