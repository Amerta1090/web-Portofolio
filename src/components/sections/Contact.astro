---
import type { Profile } from "../../types/profile";

export interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
const { contact } = profile;
---

<div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8">
  <div class="grid md:grid-cols-2 gap-8 md:gap-12">
    <div>
      <div class="flex items-center gap-3 mb-4">
        <span class="w-2 h-2 bg-accent pulse-ring" />
        <h3 class="text-lg font-black uppercase tracking-wider text-text-primary">Get in Touch</h3>
      </div>
      <p class="text-text-secondary font-mono text-sm mb-8 leading-relaxed">
        Have a question, project idea, or just want to connect? Feel free to reach out.
      </p>
      <div class="space-y-3">
        <a
          href={`mailto:${contact.email}`}
          class="flex items-center gap-3 text-text-secondary hover:text-accent transition-colors group"
        >
          <span class="w-8 h-8 border border-accent/20 flex items-center justify-center group-hover:border-accent/60 transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </span>
          <span class="text-sm font-mono">{contact.email}</span>
        </a>
        <a
          href={contact.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 text-text-secondary hover:text-accent transition-colors group"
        >
          <span class="w-8 h-8 border border-accent/20 flex items-center justify-center group-hover:border-accent/60 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
            </svg>
          </span>
          <span class="text-sm font-mono">LinkedIn</span>
        </a>
        <a
          href={contact.github}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 text-text-secondary hover:text-accent transition-colors group"
        >
          <span class="w-8 h-8 border border-accent/20 flex items-center justify-center group-hover:border-accent/60 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
          </span>
          <span class="text-sm font-mono">GitHub</span>
        </a>
      </div>
    </div>
    <div>
      <form
        id="contact-form-home"
        class="space-y-4"
      >
        <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
        <input type="hidden" name="subject" value="New contact from portfolio" />
        <input type="hidden" name="from_name" value={profile.name} />
        <div>
          <label for="name-home" class="block text-xs font-mono text-text-secondary uppercase tracking-wider mb-1">Name</label>
          <input
            type="text"
            id="name-home"
            name="name"
            required
            class="w-full px-4 py-3 bg-bg-secondary/50 border border-accent/20 text-text-primary placeholder:text-text-secondary/30 focus:outline-none focus:border-accent transition-colors font-mono text-sm"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email-home" class="block text-xs font-mono text-text-secondary uppercase tracking-wider mb-1">Email</label>
          <input
            type="email"
            id="email-home"
            name="email"
            required
            class="w-full px-4 py-3 bg-bg-secondary/50 border border-accent/20 text-text-primary placeholder:text-text-secondary/30 focus:outline-none focus:border-accent transition-colors font-mono text-sm"
            placeholder="your@email.com"
          />
        </div>
        <div>
          <label for="message-home" class="block text-xs font-mono text-text-secondary uppercase tracking-wider mb-1">Message</label>
          <textarea
            id="message-home"
            name="message"
            required
            rows={4}
            class="w-full px-4 py-3 bg-bg-secondary/50 border border-accent/20 text-text-primary placeholder:text-text-secondary/30 focus:outline-none focus:border-accent transition-colors font-mono text-sm resize-none"
            placeholder="Your message..."
          />
        </div>
        <button type="submit" class="bg-accent text-bg-primary font-black uppercase tracking-widest px-6 py-3 text-sm border-2 border-accent hover:bg-transparent hover:text-accent transition-all duration-300">
          Send Message
        </button>
        <div id="form-status-home" class="text-sm hidden"></div>
      </form>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    function showToast(message, type) {
      var existing = document.getElementById("toast-portal");
      if (existing) existing.remove();
      var portal = document.createElement("div");
      portal.id = "toast-portal";
      portal.style.cssText = "position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;gap:8px";
      document.body.appendChild(portal);
      var toast = document.createElement("div");
      toast.role = "alert";
      toast.className = "flex items-center gap-3 px-5 py-3 text-sm font-mono " + (type === "success" ? "bg-accent text-bg-primary" : "bg-accent-muted text-white");
      toast.style.animation = "toast-in 0.3s ease-out";
      var icon = document.createElement("span");
      icon.innerHTML = type === "success"
        ? '<svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>'
        : '<svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>';
      toast.appendChild(icon);
      var msg = document.createElement("span");
      msg.textContent = message;
      toast.appendChild(msg);
      portal.appendChild(toast);
      setTimeout(function() { toast.style.opacity = "0"; toast.style.transform = "translateY(1rem)"; toast.style.transition = "all 0.3s ease"; setTimeout(function() { portal.remove(); }, 300); }, 4000);
    }
    var style = document.createElement("style");
    style.textContent = "@keyframes toast-in { from { opacity: 0; transform: translateY(1rem); } to { opacity: 1; transform: translateY(0); } }";
    document.head.appendChild(style);

    var form = document.getElementById("contact-form-home");
    if (!form) return;
    var status = document.getElementById("form-status-home");
    form.addEventListener("submit", async function(e) {
      e.preventDefault();
      var btn = form.querySelector('button[type="submit"]');
      var origText = btn.textContent;
      btn.textContent = "Sending...";
      btn.disabled = true;
      if (status) { status.className = "text-sm hidden"; }
      try {
        var data = new FormData(form);
        var resp = await fetch("https://api.web3forms.com/submit", { method: "POST", body: data });
        var json = await resp.json();
        if (json.success) {
          showToast("Message sent successfully! I'll get back to you soon.", "success");
          form.reset();
        } else {
          showToast(json.message || "Failed to send. Please try again or email me directly.", "error");
        }
      } catch {
        showToast("Network error. Please email me directly at abdulmajidr708@gmail.com", "error");
      }
      btn.textContent = origText;
      btn.disabled = false;
    });
  })();
</script>
