---
import type { Profile } from "../../types/profile";
import Container from "../ui/Container.astro";

export interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
const { metrics } = profile;

const metricItems = [
  { label: "Years Experience", value: metrics.years_experience, suffix: "+" },
  { label: "Projects Shipped", value: metrics.projects_shipped },
  { label: "Certifications", value: metrics.certifications },
  { label: "Languages", value: metrics.languages.length, suffix: "" },
];
---

<Container size="md">
  <div class="grid md:grid-cols-5 gap-8 md:gap-12 items-start">
    <div class="md:col-span-3">
      <p class="text-text-primary leading-relaxed text-lg">
        {profile.summary}
      </p>
    </div>
    <div class="md:col-span-2 grid grid-cols-2 gap-4">
      {
        metricItems.map((item) => (
          <div class="bg-bg-secondary border border-border rounded-xl p-4 text-center">
            <div class="text-2xl md:text-3xl font-bold text-accent">
              {item.value}{item.suffix ?? ""}
            </div>
            <div class="mt-1 text-sm text-text-secondary">{item.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</Container>
