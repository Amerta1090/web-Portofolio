---
import type { Project } from "../../types/projects";
import Card from "../ui/Card.astro";
import Tag from "../ui/Tag.astro";

export interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

function slugify(title: string): string {
  return title.toLowerCase().replace(/[^a-z0-9]+/g, "-");
}
---

<div class="grid md:grid-cols-2 gap-6">
  {
    projects.map((project) => (
      <Card href={`/projects/${slugify(project.title)}`} variant="elevated">
        <div class="flex items-start justify-between gap-2 mb-2">
          <h3 class="text-lg font-semibold text-text-primary line-clamp-2">
            {project.title}
          </h3>
          {project.category && (
            <span class="inline-flex items-center px-2 py-0.5 text-xs bg-accent-muted/20 text-accent rounded-full shrink-0 mt-1">{project.category.toUpperCase()}</span>
          )}
        </div>
        <p class="text-text-secondary text-sm line-clamp-2 mb-3">
          {project.description}
        </p>
        {project.period && (
          <p class="text-xs text-text-secondary mb-3">{project.period}</p>
        )}
        <div class="flex flex-wrap gap-1.5" slot="footer">
          {project.skills.slice(0, 4).map((skill) => <Tag>{skill}</Tag>)}
          {project.skills.length > 4 && (
            <Tag>+{project.skills.length - 4}</Tag>
          )}
        </div>
      </Card>
    ))
  }
</div>
