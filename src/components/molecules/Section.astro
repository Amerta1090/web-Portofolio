---
export interface Props {
  title?: string;
  subtitle?: string;
  id?: string;
  variant?: "default" | "alt";
  class?: string;
  ariaLabel?: string;
  "data-reveal"?: boolean;
}

const { title, subtitle, id, variant = "default", class: className, ariaLabel } = Astro.props;

const cls = `py-16 md:py-32 relative overflow-hidden ${variant === "alt" ? "bg-bg-secondary border-y border-accent/10" : ""} ${className ?? ""}`;
const revealAttr = Astro.props["data-reveal"] ? { "data-reveal": "" } : {};
---

<section id={id} class={cls} aria-label={ariaLabel ?? title} {...revealAttr}>
  {variant === "alt" && <div class="absolute inset-0 p5-halftone-bg opacity-5 pointer-events-none mix-blend-overlay"></div>}
  
  {/* Decorative slash */}
  {variant === "alt" && (
    <div class="absolute top-0 right-0 w-48 h-48 border-r border-t border-accent/10 pointer-events-none"></div>
  )}
  
  <div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8 relative z-10">
    {
      title && (
        <div class="mb-12 relative">
          <div class="flex items-center gap-3 mb-2">
            <span class="w-2 h-2 bg-accent"></span>
            <span class="text-xs font-mono text-accent tracking-[0.2em] uppercase">Section</span>
          </div>
          <h2 class="text-4xl md:text-7xl font-black uppercase tracking-tighter text-text-primary" style="transform: skewX(-12deg);">
            {title}
          </h2>
          {subtitle && (
            <div class="inline-block border-l-4 border-accent pl-4 mt-3" style="transform: skewX(-12deg);">
              <p class="text-text-secondary font-mono text-sm" style="transform: skewX(12deg);">{subtitle}</p>
            </div>
          )}
        </div>
      )
    }
    <div style="transform: skewX(-5deg);">
      <div style="transform: skewX(5deg);">
        <slot />
      </div>
    </div>
  </div>
</section>
