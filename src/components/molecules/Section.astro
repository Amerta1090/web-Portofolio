---
export interface Props {
  title?: string;
  subtitle?: string;
  id?: string;
  variant?: "default" | "alt";
  class?: string;
  ariaLabel?: string;
  "data-reveal"?: boolean;
}

const { title, subtitle, id, variant = "default", class: className, ariaLabel } = Astro.props;

const cls = `py-16 md:py-32 relative overflow-hidden ${variant === "alt" ? "bg-bg-secondary border-y border-border" : ""} ${className ?? ""}`;
const revealAttr = Astro.props["data-reveal"] ? { "data-reveal": "" } : {};
---

<section id={id} class={cls} aria-label={ariaLabel ?? title} {...revealAttr}>
  <div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8 relative z-10">
    {
      title && (
        <div class="mb-12">
          <div class="flex items-center gap-3 mb-3">
            <span class="w-1.5 h-1.5 bg-brand rounded-full"></span>
            <span class="text-xs text-text-secondary">Section</span>
          </div>
          <h2 class="text-4xl md:text-6xl font-bold text-text-primary">
            {title}
          </h2>
          {subtitle && (
            <div class="mt-3">
              <p class="text-text-secondary text-sm">{subtitle}</p>
            </div>
          )}
        </div>
      )
    }
    <slot />
  </div>
</section>
