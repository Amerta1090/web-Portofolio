---
export interface Props {
  title?: string;
  description?: string;
  href?: string;
  variant?: "default" | "elevated" | "interactive";
  class?: string;
}

const { title, description, href, variant = "default", class: className } = Astro.props;

const variants: Record<string, string> = {
  default: "shadow-sm",
  elevated: "shadow-md",
  interactive: "hover:-translate-y-0.5 hover:shadow-md transition-all duration-200 cursor-pointer",
};

const cls = `block rounded-lg border bg-surface-primary text-text-primary p-6 ${variants[variant]} ${className ?? ""}`;
const Tag = href ? "a" : "div";
---

<Tag href={href} class={cls}>
  {title && <h3 class="text-lg font-semibold leading-none tracking-tight mb-2">{title}</h3>}
  {description && <p class="text-sm text-text-secondary leading-relaxed">{description}</p>}
  <slot name="media" />
  <slot />
  <slot name="footer" />
</Tag>
