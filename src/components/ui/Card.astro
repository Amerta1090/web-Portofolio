---
export interface Props {
  title?: string;
  description?: string;
  href?: string;
  variant?: "default" | "elevated" | "glass";
  class?: string;
}

const { title, description, href, variant = "default", class: className } = Astro.props;

const variants: Record<string, string> = {
  default:
    "bg-bg-secondary border border-border rounded-xl hover:border-accent/30 transition-all duration-200",
  elevated:
    "bg-bg-secondary border border-border rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200 card-glow",
  glass:
    "bg-bg-secondary/80 backdrop-blur-sm border border-border rounded-xl transition-all duration-200 card-glow",
};

const cls = `block p-6 ${variants[variant]} ${className ?? ""}`;
const Tag = href ? "a" : "div";
---

<Tag href={href} class={cls}>
  {title && <h3 class="text-lg font-semibold text-text-primary mb-2">{title}</h3>}
  {description && <p class="text-text-secondary text-sm line-clamp-2">{description}</p>}
  <slot name="media" />
  <slot />
  <slot name="footer" />
</Tag>
