---
export interface Props {
  title?: string;
  description?: string;
  href?: string;
  variant?: "default" | "elevated" | "glass";
  class?: string;
}

const { title, description, href, variant = "default", class: className } = Astro.props;

const variants: Record<string, string> = {
  default:
    "bg-bg-secondary border border-accent/10 hover:border-accent/40 transition-all duration-200",
  elevated:
    "bg-bg-secondary border border-accent/10 shadow-[4px_4px_0_var(--accent)] hover:shadow-[6px_6px_0_var(--accent-muted)] hover:-translate-y-0.5 transition-all duration-200",
  glass:
    "bg-bg-secondary/80 backdrop-blur-sm border border-accent/10 transition-all duration-200",
};

const cls = `block p-6 ${variants[variant]} ${className ?? ""}`;
const Tag = href ? "a" : "div";
---

<Tag href={href} class={cls}>
  {title && <h3 class="text-lg font-black uppercase tracking-wider text-text-primary mb-2">{title}</h3>}
  {description && <p class="text-text-secondary text-sm leading-relaxed">{description}</p>}
  <slot name="media" />
  <slot />
  <slot name="footer" />
</Tag>
