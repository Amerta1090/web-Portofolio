---
export interface Props {
  variant?: "default" | "accent" | "success";
  class?: string;
}

const { variant = "default", class: className } = Astro.props;

const variants: Record<string, string> = {
  default: "bg-bg-tertiary border border-accent/20 text-text-secondary",
  accent: "bg-accent/10 border border-accent/30 text-accent",
  success: "bg-green-900/20 border border-green-500/30 text-green-400",
};

const cls = `inline-flex items-center px-2.5 py-0.5 text-[10px] font-mono uppercase tracking-wider ${variants[variant]} ${className ?? ""}`;
---

<span class={cls}>
  <slot />
</span>
