---
export interface Props {
  title?: string;
  subtitle?: string;
  id?: string;
  variant?: "default" | "alt";
  class?: string;
  ariaLabel?: string;
  "data-reveal"?: boolean;
}

const { title, subtitle, id, variant = "default", class: className, ariaLabel } = Astro.props;

const cls = `py-12 md:py-24 ${variant === "alt" ? "bg-bg-secondary" : ""} ${className ?? ""}`;
const revealAttr = Astro.props["data-reveal"] ? { "data-reveal": "" } : {};
---

<section id={id} class={cls} aria-label={ariaLabel ?? title} {...revealAttr}>
  <div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8">
    {
      title && (
        <div class="mb-12">
          <h2 class="text-2xl md:text-4xl font-semibold text-text-primary">
            {title}
          </h2>
          {subtitle && <p class="mt-2 text-text-secondary text-lg">{subtitle}</p>}
        </div>
      )
    }
    <slot />
  </div>
</section>
