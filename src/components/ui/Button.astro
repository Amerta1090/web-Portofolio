---
export interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg";
  type?: "button" | "submit" | "reset";
  class?: string;
}

const { href, variant = "primary", size = "md", type = "button", class: className } = Astro.props;

const variants: Record<string, string> = {
  primary: "bg-accent text-bg-primary hover:brightness-110 active:scale-[0.98]",
  secondary: "border border-border text-text-primary hover:bg-bg-tertiary active:scale-[0.98]",
  ghost: "text-text-secondary hover:text-text-primary hover:bg-bg-tertiary",
};

const sizes: Record<string, string> = {
  sm: "px-3 py-1.5 text-sm",
  md: "px-5 py-2.5 text-base",
  lg: "px-7 py-3 text-lg",
};

const cls = `inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 ease focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-primary ${variants[variant]} ${sizes[size]} ${className ?? ""}`;
---

{
  href ? (
    <a href={href} class={cls}>
      <slot />
    </a>
  ) : (
    <button type={type} class={cls}>
      <slot />
    </button>
  )
}
