---
// Inline script that enables scroll-triggered fade-up animations
// for elements with the `data-reveal` attribute.
// This runs in the client and respects prefers-reduced-motion.
---

<script is:inline>
  (function () {
    const motionOk = !window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!motionOk) return;

    const reveal = (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          observer.unobserve(entry.target);
        }
      }
    };

    const observer = new IntersectionObserver(reveal, { threshold: 0.05 });
    const els = document.querySelectorAll("[data-reveal]");
    for (const el of els) observer.observe(el);
  })();
</script>

<style>
  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
    }
  }
</style>
