---
import "../styles/global.css";
import "../styles/theme.css";
import ClientRouter from "astro/components/ClientRouter.astro";
import Footer from "../components/templates/Footer.astro";
import Header from "../components/templates/Header.astro";
import SmoothScroll from "../islands/SmoothScroll";
import ScrollProgress from "../islands/ScrollProgress";
import { Toaster } from "sonner";
import { SITE } from "../lib/constants";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title = SITE.title,
  description = SITE.description,
  ogImage = "/og-image.png",
  ogType = "website",
  canonicalUrl,
} = Astro.props;

const canonical = canonicalUrl ?? SITE.url;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${SITE.url}${ogImage}`;
const currentPath = Astro.url.pathname;

const cfAnalyticsToken = import.meta.env.CF_ANALYTICS_TOKEN;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.author} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" id="favicon" />
    <link rel="canonical" href={canonical} />
    <ClientRouter />

    <script is:inline type="application/ld+json">
      {JSON.stringify(Astro.props.jsonLd ?? {
        "@context": "https://schema.org",
        "@type": "Person",
        name: SITE.author,
        jobTitle: "AI/ML Engineer & Systems Builder",
        url: SITE.url,
        sameAs: [SITE.github, SITE.linkedin],
      })}
    </script>

    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-700.woff2" as="font" type="font/woff2" crossorigin />

    <script is:inline>
      (function () {
        const prefetched = new Set();
        const prefetch = (url) => {
          if (prefetched.has(url)) return;
          prefetched.add(url);
          const link = document.createElement("link");
          link.rel = "prefetch";
          link.href = url;
          document.head.appendChild(link);
        };
        document.addEventListener("mouseover", (e) => {
          const a = e.target.closest?.("a");
          if (a && a.href && a.href.startsWith(location.origin) && !a.href.includes("#")) {
            prefetch(a.href);
          }
        }, { passive: true });
        document.addEventListener("touchstart", (e) => {
          const a = e.target.closest?.("a");
          if (a && a.href && a.href.startsWith(location.origin) && !a.href.includes("#")) {
            prefetch(a.href);
          }
        }, { passive: true });
      })();
    </script>

    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "light" || (!stored && !prefersDark)) {
          document.documentElement.classList.remove("dark");
        } else {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>

    <script is:inline src="https://unpkg.com/@dotlottie/player-component@latest/dist/dotlottie-player.js" defer></script>

    <script is:inline>
      (function () {
        const updateFavicon = function () {
          const isDark = document.documentElement.classList.contains("dark");
          const link = document.getElementById("favicon");
          if (link) {
            link.setAttribute("href", isDark ? "/favicon.svg" : "/favicon-light.svg");
          }
        };
        const observer = new MutationObserver(function () { updateFavicon(); });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });
        updateFavicon();
      })();
    </script>

    {cfAnalyticsToken && (
      <script is:inline data-cf-beacon={JSON.stringify({ token: cfAnalyticsToken })} src="https://static.cloudflareinsights.com/beacon.min.js" defer></script>
    )}
  </head>
  <body class="min-h-screen bg-bg-primary text-text-primary">

    <div class="relative z-10">
      <a href="#main-content" class="skip-to-content">Skip to content</a>
      <SmoothScroll client:load />
      <ScrollProgress client:load />
      <Header currentPath={currentPath} />
      <main id="main-content" class="pt-16">
        <slot />
      </main>
      <Footer />
    </div>
    <Toaster
      client:load
      position="bottom-right"
      toastOptions={{
        style: {
          background: "var(--color-surface-secondary)",
          color: "var(--color-text-primary)",
          border: "1px solid var(--color-border)",
        },
      }}
    />
  </body>
</html>
