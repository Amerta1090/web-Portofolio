---
import "../styles/global.css";
import "../styles/theme.css";
import ClientRouter from "astro/components/ClientRouter.astro";
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import ScrollProgress from "../islands/ScrollProgress";
import { SITE } from "../lib/constants";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title = SITE.title,
  description = SITE.description,
  ogImage = "/og-image.png",
  ogType = "website",
  canonicalUrl,
} = Astro.props;

const canonical = canonicalUrl ?? SITE.url;
const ogImageUrl = ogImage.startsWith("http") ? ogImage : `${SITE.url}${ogImage}`;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.author} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" id="favicon" />
    <link rel="canonical" href={canonical} />
    <ClientRouter />

    <script is:inline type="application/ld+json">
      {JSON.stringify(Astro.props.jsonLd ?? {
        "@context": "https://schema.org",
        "@type": "Person",
        name: SITE.author,
        jobTitle: "AI/ML Engineer & Systems Builder",
        url: SITE.url,
        sameAs: [SITE.github, SITE.linkedin],
      })}
    </script>

    <script is:inline>
      // Prevent FOUC — apply theme before render
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "light" || (!stored && !prefersDark)) {
          document.documentElement.classList.remove("dark");
        } else {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>

    <script is:inline>
      // Dynamic favicon — swaps between dark/light variant
      (function () {
        const updateFavicon = function () {
          const isDark = document.documentElement.classList.contains("dark");
          const link = document.getElementById("favicon");
          if (link) {
            link.setAttribute("href", isDark ? "/favicon.svg" : "/favicon-light.svg");
          }
        };
        // Watch for theme changes via mutation
        const observer = new MutationObserver(function () { updateFavicon(); });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });
        updateFavicon();
      })();
    </script>
  </head>
  <body class="min-h-screen bg-bg-primary text-text-primary noise-overlay">
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <ScrollProgress client:load />
    <Header />
    <main id="main-content" class="pt-16">
      <slot />
    </main>
    <Footer />
  </body>
</html>
