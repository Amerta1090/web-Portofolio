---

<article class="py-12 md:py-24 blog-content">
  <slot />
</article>

<style is:global>
  .blog-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .blog-content h1 {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .blog-content h2 {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.3;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--text-primary);
  }

  .blog-content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.4;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .blog-content h4 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .blog-content p {
    margin-bottom: 1.25rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .blog-content strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .blog-content ul,
  .blog-content ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .blog-content li {
    margin-bottom: 0.25rem;
  }

  .blog-content ul li {
    list-style-type: disc;
  }

  .blog-content ol li {
    list-style-type: decimal;
  }

  .blog-content a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity var(--transition-fast);
  }

  .blog-content a:hover {
    opacity: 0.8;
  }

  .blog-content blockquote {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .blog-content code {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.875rem;
    background: var(--bg-tertiary);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--accent);
  }

  .blog-content pre {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    margin: 1.5rem 0;
    overflow-x: auto;
  }

  .blog-content pre code {
    background: none;
    padding: 0;
    color: var(--text-primary);
    font-size: 0.8125rem;
    line-height: 1.6;
  }

  .blog-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }

  .blog-content th {
    text-align: left;
    font-weight: 600;
    color: var(--text-primary);
    padding: 0.75rem 0.5rem;
    border-bottom: 2px solid var(--border);
  }

  .blog-content td {
    padding: 0.75rem 0.5rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-secondary);
  }

  .blog-content tr:last-child td {
    border-bottom: none;
  }

  .blog-content hr {
    border: none;
    height: 1px;
    background: var(--border);
    margin: 2rem 0;
  }

  .blog-content img {
    border-radius: 8px;
    margin: 1.5rem 0;
    border: 1px solid var(--border);
  }

  .blog-content :not(pre) > code {
    word-break: break-word;
  }

  .blog-content .astro-code {
    padding: 1rem;
    border-radius: 8px;
    margin: 1.5rem 0;
  }
</style>
