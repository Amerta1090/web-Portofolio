---
import Container from "../components/ui/Container.astro";
import Section from "../components/ui/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getProfile } from "../lib/data";

const profile = getProfile();
---

<BaseLayout>
  <!-- Hero -->
  <Section id="hero">
    <Container size="sm">
      <div class="min-h-[calc(100vh-4rem)] flex flex-col justify-center">
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-text-primary leading-tight">
          {profile.name}
        </h1>
        <p class="mt-4 text-xl md:text-2xl text-accent font-medium">
          {profile.headline}
        </p>
        <p class="mt-2 text-lg text-text-secondary max-w-xl">
          {profile.tagline}
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/#contact"
            class="inline-flex items-center px-6 py-3 bg-accent text-bg-primary font-medium rounded-lg hover:brightness-110 transition-all duration-200"
          >
            Get in Touch
          </a>
          <a
            href={profile.resume_url}
            class="inline-flex items-center px-6 py-3 border border-border text-text-primary font-medium rounded-lg hover:bg-bg-tertiary transition-all duration-200"
          >
            Download Resume
          </a>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Experience -->
  <Section id="experience" title="Experience" variant="alt">
    <p class="text-text-secondary">Experience section coming in Sprint 2.</p>
  </Section>

  <!-- Projects -->
  <Section id="projects" title="Featured Projects">
    <p class="text-text-secondary">Projects section coming in Sprint 2.</p>
  </Section>

  <!-- Skills -->
  <Section id="skills" title="Skills" variant="alt">
    <p class="text-text-secondary">Skills section coming in Sprint 2.</p>
  </Section>

  <!-- Contact -->
  <Section id="contact" title="Contact">
    <p class="text-text-secondary">Contact section coming in Sprint 2.</p>
  </Section>
</BaseLayout>
