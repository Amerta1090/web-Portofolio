---
import Section from "../components/molecules/Section.astro";
import About from "../components/organisms/About.astro";
import Certifications from "../components/organisms/Certifications.astro";
import Contact from "../components/organisms/Contact.astro";
import Experience from "../components/organisms/Experience.astro";
import GitHubShowcase from "../components/organisms/GitHubShowcase.astro";
import Honors from "../components/organisms/Honors.astro";
import Volunteering from "../components/organisms/Volunteering.astro";
import ImpactMetrics from "../islands/ImpactMetrics";
import JourneyTimeline from "../islands/JourneyTimeline";
import ProjectCardGrid from "../islands/ProjectCardGrid";
import ScrollAnimator from "../islands/ScrollAnimator.astro";
import SectionCounter from "../islands/SectionCounter";
import SkillsExplorer from "../islands/SkillsExplorer";
import TimeAwareHero from "../islands/TimeAwareHero";
import TestimonialCarousel from "../islands/TestimonialCarousel";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  getCertifications,
  getExperience,
  getFeaturedProjects,
  getHonors,
  getProfile,
  getSkills,
  getTestimonials,
  getVolunteering,
} from "../lib/data";
import { fetchAllGitHubData } from "../lib/github";

const profile = getProfile();
const featuredProjects = getFeaturedProjects();
const experiences = getExperience();
const skills = getSkills();
const certifications = getCertifications();
const honors = getHonors();
const volunteerings = getVolunteering();
const testimonials = getTestimonials();
const gitHubData = await fetchAllGitHubData();
---

<BaseLayout>
  <section id="hero" aria-label="Hero">
    <TimeAwareHero
      client:idle
      name={profile.name}
      headline={profile.headline}
      tagline={profile.tagline}
      resumeUrl={profile.resume_url}
    />
  </section>

  <Section data-reveal id="about" title="About" variant="alt" ariaLabel="About me">
    <About profile={profile} />
  </Section>

  <Section data-reveal id="experience" title="Experience" variant="alt" ariaLabel="Work experience">
    <Experience experiences={experiences} />
  </Section>

  <Section data-reveal id="journey" title="The Journey" subtitle="A scroll through my professional path" variant="alt" ariaLabel="Career journey">
    <JourneyTimeline client:visible experiences={experiences.map((e) => ({
      title: e.role,
      company: e.company,
      period: `${e.start_date} — ${e.end_date ?? "Present"}`,
      description: e.highlights?.join(". ") ?? "",
      skills: e.technologies,
    }))} />
  </Section>

  <Section data-reveal id="projects" title="Featured Projects" subtitle="Selected work that demonstrates my range" ariaLabel="Featured projects">
    <ProjectCardGrid client:load projects={featuredProjects} />
  </Section>

  <Section data-reveal id="skills" title="Skills" variant="alt" ariaLabel="Skills and technologies">
    <SkillsExplorer client:load skills={skills} />
  </Section>

  {
    certifications.length > 0 && (
      <Section data-reveal id="certifications" title="Certifications" ariaLabel="Certifications">
        <Certifications certifications={certifications} />
      </Section>
    )
  }

  {
    honors.length > 0 && (
      <Section data-reveal id="honors" title="Honors & Awards" variant="alt" ariaLabel="Honors and awards">
        <Honors honors={honors} />
      </Section>
    )
  }

  {
    volunteerings.length > 0 && (
      <Section data-reveal id="volunteering" title="Volunteering" ariaLabel="Volunteering experience">
        <Volunteering volunteerings={volunteerings} />
      </Section>
    )
  }

  {
    (gitHubData.pinned_repos.length > 0 || gitHubData.top_repos.length > 0) && (
      <Section data-reveal id="github" title="GitHub" subtitle="Recent activity and repositories" variant="alt" ariaLabel="GitHub activity">
        <GitHubShowcase data={gitHubData} />
      </Section>
    )
  }

  {
    testimonials.length > 0 && (
      <Section data-reveal id="testimonials" title="Testimonials" subtitle="What people say about working with me" variant="alt" ariaLabel="Testimonials">
        <TestimonialCarousel client:load testimonials={testimonials} autoPlay={true} interval={6000} />
      </Section>
    )
  }

  <Section data-reveal id="contact" title="Contact" subtitle="Have a question or want to work together?" ariaLabel="Contact">
    <Contact profile={profile} />
  </Section>

  <ScrollAnimator />
  <SectionCounter client:load />
</BaseLayout>
