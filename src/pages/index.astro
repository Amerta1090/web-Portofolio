---
import About from "../components/sections/About.astro";
import Certifications from "../components/sections/Certifications.astro";
import Contact from "../components/sections/Contact.astro";
import Experience from "../components/sections/Experience.astro";
import GitHubShowcase from "../components/sections/GitHubShowcase.astro";
import Hero from "../components/sections/Hero.astro";
import Honors from "../components/sections/Honors.astro";
import Projects from "../components/sections/Projects.astro";
import Skills from "../components/sections/Skills.astro";
import Volunteering from "../components/sections/Volunteering.astro";
import Section from "../components/ui/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  getCertifications,
  getExperience,
  getFeaturedProjects,
  getHonors,
  getProfile,
  getSkills,
  getVolunteering,
} from "../lib/data";
import { fetchAllGitHubData } from "../lib/github";

const profile = getProfile();
const featuredProjects = getFeaturedProjects();
const experiences = getExperience();
const skills = getSkills();
const certifications = getCertifications();
const honors = getHonors();
const volunteerings = getVolunteering();
const gitHubData = await fetchAllGitHubData();
---

<BaseLayout>
  <Section id="hero" ariaLabel="Hero">
    <Hero profile={profile} />
  </Section>

  <Section id="about" title="About" variant="alt" ariaLabel="About me">
    <About profile={profile} />
  </Section>

  <Section id="experience" title="Experience" variant="alt" ariaLabel="Work experience">
    <Experience experiences={experiences} />
  </Section>

  <Section id="projects" title="Featured Projects" subtitle="Selected work that demonstrates my range" ariaLabel="Featured projects">
    <Projects projects={featuredProjects} />
  </Section>

  <Section id="skills" title="Skills" variant="alt" ariaLabel="Skills and technologies">
    <Skills skills={skills} />
  </Section>

  {
    certifications.length > 0 && (
      <Section id="certifications" title="Certifications" ariaLabel="Certifications">
        <Certifications certifications={certifications} />
      </Section>
    )
  }

  {
    honors.length > 0 && (
      <Section id="honors" title="Honors & Awards" variant="alt" ariaLabel="Honors and awards">
        <Honors honors={honors} />
      </Section>
    )
  }

  {
    volunteerings.length > 0 && (
      <Section id="volunteering" title="Volunteering" ariaLabel="Volunteering experience">
        <Volunteering volunteerings={volunteerings} />
      </Section>
    )
  }

  {
    gitHubData.pinned_repos.length > 0 && (
      <Section id="github" title="GitHub" subtitle="Recent activity and repositories" variant="alt" ariaLabel="GitHub activity">
        <GitHubShowcase data={gitHubData} />
      </Section>
    )
  }

  <Section id="contact" title="Contact" subtitle="Have a question or want to work together?" ariaLabel="Contact">
    <Contact profile={profile} />
  </Section>
</BaseLayout>
