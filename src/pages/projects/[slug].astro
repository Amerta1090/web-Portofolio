---
import Button from "../../components/ui/Button.astro";
import Container from "../../components/ui/Container.astro";
import Tag from "../../components/ui/Tag.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getProjects } from "../../lib/data";

export async function getStaticPaths() {
  const projects = getProjects();
  return projects.map((project) => ({
    params: { slug: project.title.toLowerCase().replace(/[^a-z0-9]+/g, "-") },
    props: { project },
  }));
}

const { project } = Astro.props;

if (!project) {
  return Astro.redirect("/404");
}

const allProjects = getProjects();
const currentIndex = allProjects.findIndex((p) => p.title === project.title);
const prevProject = currentIndex > 0 ? allProjects[currentIndex - 1] : null;
const nextProject = currentIndex < allProjects.length - 1 ? allProjects[currentIndex + 1] : null;

function slugify(title: string): string {
  return title.toLowerCase().replace(/[^a-z0-9]+/g, "-");
}
---

<BaseLayout title={`${project.title} — Abdul Majid Ridwan Tyastonoatmaja`} description={project.description.slice(0, 160)} canonicalUrl={`https://abdulmajidr708.dev/projects/${slugify(project.title)}`}>
  <Container size="md">
    <article class="py-12 md:py-24">
      <div class="mb-8">
        <a
          href="/projects"
          class="text-sm text-text-secondary hover:text-accent transition-colors"
        >
          ← Back to Projects
        </a>
      </div>

      <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
        <div>
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text-primary leading-tight">
            {project.title}
          </h1>
          {project.association && (
            <p class="text-text-secondary mt-2">{project.association}</p>
          )}
          <p class="text-sm text-text-secondary mt-1">{project.period}</p>
        </div>
        {project.category && (
          <span class="inline-flex items-center px-3 py-1 text-sm bg-accent-muted/20 text-accent rounded-full font-medium">
            {project.category.toUpperCase()}
          </span>
        )}
      </div>

      <div class="flex flex-wrap gap-2 mb-8">
        {project.skills.map((skill) => <Tag>{skill}</Tag>)}
      </div>

      <div class="bg-bg-secondary border border-border rounded-xl p-6 md:p-8 mb-8">
        <p class="text-text-primary leading-relaxed text-lg">
          {project.description}
        </p>
      </div>

      {project.links && project.links.length > 0 && (
        <div class="mb-8">
          <h2 class="text-lg font-semibold text-text-primary mb-4">Links</h2>
          <div class="flex flex-wrap gap-3">
            {project.links.map((link) => (
              <Button href={link.url} variant={link.label === "GitHub Repository" ? "secondary" : "primary"}>
                {link.label}
              </Button>
            ))}
          </div>
        </div>
      )}

      {project.media && project.media.length > 0 && (
        <div class="mb-8">
          <h2 class="text-lg font-semibold text-text-primary mb-4">Gallery</h2>
          <div class="grid md:grid-cols-2 gap-4">
            {project.media.map((m) => (
              <div class="bg-bg-secondary border border-border rounded-xl p-8 text-center hover:border-accent/30 transition-colors duration-200">
                <div class="w-12 h-12 mx-auto mb-3 rounded-lg bg-accent-muted/20 flex items-center justify-center">
                  <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
                <p class="text-text-secondary text-sm">{m}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      {(prevProject || nextProject) && (
        <div class="mt-16 pt-8 border-t border-border flex flex-wrap justify-between gap-4">
          <div>
            {prevProject && (
              <a
                href={`/projects/${slugify(prevProject.title)}`}
                class="text-sm text-text-secondary hover:text-accent transition-colors"
              >
                ← {prevProject.title}
              </a>
            )}
          </div>
          <div>
            {nextProject && (
              <a
                href={`/projects/${slugify(nextProject.title)}`}
                class="text-sm text-text-secondary hover:text-accent transition-colors"
              >
                {nextProject.title} →
              </a>
            )}
          </div>
        </div>
      )}
    </article>
  </Container>
</BaseLayout>
