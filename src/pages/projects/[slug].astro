---
import { Tag } from "../../components/atoms/Tag.tsx";
import TechExplorer from "../../islands/TechExplorer";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getProjects } from "../../lib/data";
import { fetchReadme } from "../../lib/github";

export async function getStaticPaths() {
  const projects = getProjects();
  return projects.map((project) => ({
    params: { slug: project.title.toLowerCase().replace(/[^a-z0-9]+/g, "-") },
    props: { project },
  }));
}

const { project } = Astro.props;

if (!project) {
  return Astro.redirect("/404");
}

const allProjects = getProjects();
const currentIndex = allProjects.findIndex((p) => p.title === project.title);
const prevProject = currentIndex > 0 ? allProjects[currentIndex - 1] : null;
const nextProject = currentIndex < allProjects.length - 1 ? allProjects[currentIndex + 1] : null;

function slugify(title: string): string {
  return title.toLowerCase().replace(/[^a-z0-9]+/g, "-");
}

const githubLink = project.links?.find((l) => l.label.includes("GitHub"));
let readme: { content: string; fetched_at: string } | null = null;
if (githubLink) {
  const match = githubLink.url.match(/github\.com\/([^/]+)\/([^/]+?)(?:\/|$)/);
  if (match) {
    const [, owner, repoName] = match;
    readme = await fetchReadme(owner, repoName);
  }
}

function extractReadmeSection(content: string, heading: string): string | null {
  const regex = new RegExp(`##\\s*${heading}[\\s\\S]*?(?=\\n##\\s|$)`, "i");
  const match = content.match(regex);
  if (!match) return null;
  return match[0]
    .replace(/```[\s\S]*?```/g, "")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/[#*`]/g, "")
    .trim();
}
---

<BaseLayout title={`${project.title} — Abdul Majid Ridwan Tyastonoatmaja`} description={project.description.slice(0, 160)} canonicalUrl={`https://abdulmajidr708.dev/projects/${slugify(project.title)}`}>
  <div class="py-12 md:py-24">
    <div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <a href="/projects" class="text-sm text-text-secondary hover:text-accent transition-colors">&larr; Back to Projects</a>
      </div>

      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
        <nav class="lg:w-48 shrink-0 hidden lg:block" aria-label="Project sections">
          <div class="lg:sticky lg:top-24 space-y-1">
            <a href="#overview" class="block px-3 py-2 text-sm text-text-secondary hover:text-accent hover:bg-bg-tertiary rounded-lg transition-all">Overview</a>
            <a href="#highlights" class="block px-3 py-2 text-sm text-text-secondary hover:text-accent hover:bg-bg-tertiary rounded-lg transition-all">Highlights</a>
            <a href="#technologies" class="block px-3 py-2 text-sm text-text-secondary hover:text-accent hover:bg-bg-tertiary rounded-lg transition-all">Technologies</a>
            <a href="#links" class="block px-3 py-2 text-sm text-text-secondary hover:text-accent hover:bg-bg-tertiary rounded-lg transition-all">Links</a>
          </div>
        </nav>

        <article class="flex-1 min-w-0">
          <header id="overview" class="mb-8">
            <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
              <div>
                <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text-primary leading-tight">{project.title}</h1>
                {project.association && <p class="text-text-secondary mt-2">{project.association}</p>}
                <p class="text-sm text-text-secondary mt-1">{project.period}</p>
              </div>
              {project.category && (
                <span class="inline-flex items-center px-3 py-1 text-sm bg-accent-muted/20 text-accent rounded-full font-medium shrink-0">{project.category.toUpperCase()}</span>
              )}
            </div>
          </header>

          <section id="highlights" class="mb-10">
            <h2 class="text-xl font-semibold text-text-primary mb-4">Highlights</h2>
            <div class="bg-bg-secondary border border-border rounded-xl p-6 md:p-8">
              <p class="text-text-primary leading-relaxed text-lg">{project.description}</p>
            </div>
          </section>

          <section id="technologies" class="mb-10">
            <h2 class="text-xl font-semibold text-text-primary mb-4">Technologies Used</h2>
            <div class="bg-bg-secondary border border-border rounded-xl p-6">
              <TechExplorer client:load skills={project.skills} />
            </div>
            <div class="flex flex-wrap gap-2 mt-4">
              {project.skills.map((skill) => <Tag>{skill}</Tag>)}
            </div>
          </section>

          {project.links && project.links.length > 0 && (
            <section id="links" class="mb-10">
              <h2 class="text-xl font-semibold text-text-primary mb-4">Links</h2>
              <div class="flex flex-wrap gap-3">
                {project.links.map((link) => (
                  <a href={link.url} target="_blank" rel="noopener noreferrer"
                    class="inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 ease focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-bg-primary px-5 py-2.5 text-base"
                    class:list={[
                      link.label === "GitHub Repository"
                        ? "border border-border text-text-primary hover:bg-bg-tertiary active:scale-[0.98]"
                        : "bg-accent text-bg-primary hover:brightness-110 active:scale-[0.98]"
                    ]}
                  >{link.label}</a>
                ))}
              </div>
            </section>
          )}

          {readme && (
            <section id="readme" class="mb-10">
              <h2 class="text-xl font-semibold text-text-primary mb-4">From GitHub README</h2>
              <div class="bg-bg-secondary border border-border rounded-xl p-6 md:p-8">
                <div class="prose prose-sm max-w-none text-text-secondary space-y-4">
                  {extractReadmeSection(readme.content, "Description") && (
                    <div>
                      <h3 class="text-sm font-semibold text-text-primary mb-2">Description</h3>
                      <p class="leading-relaxed">{extractReadmeSection(readme.content, "Description")}</p>
                    </div>
                  )}
                  {extractReadmeSection(readme.content, "Features") && (
                    <div>
                      <h3 class="text-sm font-semibold text-text-primary mb-2">Features</h3>
                      <p class="leading-relaxed">{extractReadmeSection(readme.content, "Features")}</p>
                    </div>
                  )}
                  {extractReadmeSection(readme.content, "Installation") && (
                    <div>
                      <h3 class="text-sm font-semibold text-text-primary mb-2">Installation</h3>
                      <p class="leading-relaxed text-xs">{extractReadmeSection(readme.content, "Installation")}</p>
                    </div>
                  )}
                  {extractReadmeSection(readme.content, "Tech") && (
                    <div>
                      <h3 class="text-sm font-semibold text-text-primary mb-2">Tech Stack</h3>
                      <p class="leading-relaxed">{extractReadmeSection(readme.content, "Tech")}</p>
                    </div>
                  )}
                </div>
                <div class="mt-6 pt-4 border-t border-border">
                  <p class="text-xs text-text-secondary">
                    Synced from GitHub · {new Date(readme.fetched_at).toLocaleDateString("en-US", {
                      year: "numeric", month: "short", day: "numeric",
                      hour: "2-digit", minute: "2-digit",
                    })}
                  </p>
                </div>
              </div>
            </section>
          )}

          {project.media && project.media.length > 0 && (
            <section class="mb-10">
              <h2 class="text-xl font-semibold text-text-primary mb-4">Gallery</h2>
              <div class="grid md:grid-cols-2 gap-4">
                {project.media.map((m) => (
                  <button type="button" data-lightbox class="bg-bg-secondary border border-border rounded-xl p-8 text-center hover:border-accent/30 transition-all duration-200 cursor-pointer group relative overflow-hidden"
                    onClick="this.querySelector('.lightbox-overlay')?.classList.remove('hidden')"
                  >
                    <div class="w-12 h-12 mx-auto mb-3 rounded-lg bg-accent-muted/20 flex items-center justify-center group-hover:scale-110 transition-transform duration-200">
                      <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                        <circle cx="8.5" cy="8.5" r="1.5" />
                        <path d="M21 15l-5-5L5 21" />
                      </svg>
                    </div>
                    <p class="text-text-secondary text-sm">{m}</p>
                  </button>
                ))}
              </div>
            </section>
          )}

          {(prevProject || nextProject) && (
            <div class="mt-16 pt-8 border-t border-border flex flex-wrap justify-between gap-4">
              <div>
                {prevProject && (
                  <a href={`/projects/${slugify(prevProject.title)}`} class="text-sm text-text-secondary hover:text-accent transition-colors">&larr; {prevProject.title}</a>
                )}
              </div>
              <div>
                {nextProject && (
                  <a href={`/projects/${slugify(nextProject.title)}`} class="text-sm text-text-secondary hover:text-accent transition-colors">{nextProject.title} &rarr;</a>
                )}
              </div>
            </div>
          )}
        </article>
      </div>
    </div>
  </div>
</BaseLayout>
