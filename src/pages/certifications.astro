---
import Badge from "../components/ui/Badge.astro";
import Section from "../components/ui/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCertifications } from "../lib/data";
import type { Certification } from "../types/certifications";

const certifications = getCertifications();

function formatDate(date: string | null): string {
  if (!date) return "";
  const [year, month] = date.split("-");
  const months = [
    "Jan",
    "Feb",
    "Mar",
    "Apr",
    "May",
    "Jun",
    "Jul",
    "Aug",
    "Sep",
    "Oct",
    "Nov",
    "Dec",
  ];
  return month ? `${months[Number.parseInt(month) - 1]} ${year}` : year;
}

const grouped = certifications.reduce((acc: Record<string, Certification[]>, cert) => {
  const issuer = cert.issuer || "Other";
  if (!acc[issuer]) acc[issuer] = [];
  acc[issuer].push(cert);
  return acc;
}, {});
---

<BaseLayout title="Certifications — Abdul Majid Ridwan Tyastonoatmaja" description={`${certifications.length} professional certifications in AI, ML, data science, and more.`}>
  <Section title="Certifications" subtitle={`${certifications.length} professional certifications`}>
    <div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8">
      <div class="mb-6">
        <input
          type="text"
          id="cert-search"
          placeholder="Search certifications..."
          class="w-full max-w-md px-4 py-2.5 bg-bg-secondary border border-border rounded-lg text-text-primary placeholder-text-secondary focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition-all duration-200"
          oninput="filterCertifications(this.value)"
        />
      </div>
      <div id="cert-list" class="space-y-4">
        {Object.entries(grouped).map(([issuer, certs]) => (
          <details class="group bg-bg-secondary border border-border rounded-xl overflow-hidden" data-issuer={issuer}>
            <summary class="flex items-center justify-between p-4 cursor-pointer hover:bg-bg-tertiary transition-colors duration-200 list-none">
              <div class="flex items-center gap-3">
                <h3 class="font-medium text-text-primary">{issuer}</h3>
                <Badge>{certs.length}</Badge>
              </div>
              <svg
                class="w-5 h-5 text-text-secondary group-open:rotate-180 transition-transform duration-200"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="border-t border-border">
              {certs.map((cert) => (
                <div class="p-4 border-b border-border last:border-b-0 hover:bg-bg-tertiary/50 transition-colors" data-search={`${cert.title} ${cert.issuer} ${cert.skills.join(" ")}`}>
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <p class="text-text-primary text-sm font-medium">
                        {cert.url
                          ? <a href={cert.url} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">{cert.title}</a>
                          : cert.title
                        }
                      </p>
                      {cert.date && (
                        <p class="text-xs text-text-secondary mt-0.5">{formatDate(cert.date)}</p>
                      )}
                    </div>
                    {cert.credential_id && (
                      <span class="text-xs text-text-secondary flex-shrink-0">ID: {cert.credential_id}</span>
                    )}
                  </div>
                  {cert.skills && cert.skills.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mt-2">
                      {cert.skills.map((skill) => (
                        <span class="inline-flex items-center px-2 py-0.5 text-xs bg-bg-tertiary text-text-secondary rounded-full">{skill}</span>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </details>
        ))}
      </div>
    </div>
  </Section>
</BaseLayout>

<script is:inline>
  function filterCertifications(query) {
    const term = query.toLowerCase().trim();
    const items = document.querySelectorAll("#cert-list details");
    for (const item of items) {
      const certItems = item.querySelectorAll("[data-search]");
      let groupHasMatch = false;
      for (const cert of certItems) {
        const text = (cert.getAttribute("data-search") || "").toLowerCase();
        const match = !term || text.includes(term);
        cert.style.display = match ? "" : "none";
        if (match) groupHasMatch = true;
      }
      item.style.display = groupHasMatch ? "" : "none";
    }
  }
</script>
