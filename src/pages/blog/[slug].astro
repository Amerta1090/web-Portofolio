---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogLayout from "../../layouts/BlogLayout.astro";
import Tag from "../../components/ui/Tag.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { slug: post.id },
  }));
}

const { slug } = Astro.props;

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const post = allPosts.find((p) => p.id === slug);

if (!post) {
  return Astro.redirect("/404");
}

const { Content, headings } = await render(post);

const currentIndex = allPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const nextPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;

const relatedPosts = allPosts
  .filter(
    (p) =>
      p.id !== post.id &&
      p.data.tags.some((t: string) => post.data.tags.includes(t)),
  )
  .slice(0, 3);

const seriesPosts = post.data.series
  ? allPosts
      .filter((p) => p.data.series === post.data.series && p.id !== post.id)
      .sort((a, b) => (a.data.seriesOrder ?? 99) - (b.data.seriesOrder ?? 99))
  : [];

const allSeriesPosts = post.data.series
  ? [post, ...seriesPosts].sort((a, b) => (a.data.seriesOrder ?? 99) - (b.data.seriesOrder ?? 99))
  : [];

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}

function readingTime(body: string): number {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

function tagUrl(tag: string): string {
  return "/blog/tag/" + tag.replace(/\//g, "~");
}

const toc = headings
  .filter((h: { depth: number }) => h.depth <= 3)
  .map((h: { depth: number; slug: string; text: string }) => ({
    slug: h.slug,
    text: h.text,
    isSub: h.depth === 3,
  }));

const canonicalUrl = "https://abdulmajidr708.dev/blog/" + post.id;
const shareText = encodeURIComponent(post.data.title);
const shareUrl = encodeURIComponent(canonicalUrl);
const twitterShareUrl = "https://twitter.com/intent/tweet?text=" + shareText + "&url=" + shareUrl;
const linkedinShareUrl = "https://www.linkedin.com/sharing/share-offsite/?url=" + shareUrl;
---

<BaseLayout
  title={post.data.title + " — Abdul Majid Ridwan Tyastonoatmaja"}
  description={post.data.description}
  ogImage={post.data.image}
  canonicalUrl={canonicalUrl}
>
  <div class="py-12 md:py-24">
    <div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8">
      <div class="mb-8">
        <a href="/blog" class="text-sm text-text-secondary hover:text-accent transition-colors">
          ← Back to Blog
        </a>
      </div>

      <div class="flex flex-col lg:flex-row gap-8">
        {headings.length > 0 && (
          <aside class="lg:w-56 shrink-0">
            <div class="lg:sticky lg:top-24">
              <h4 class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-3">
                On this page
              </h4>
              <nav class="space-y-1">
                {toc.map((h) => (
                  <a
                    href={"#" + h.slug}
                    class={"block text-sm py-1 text-text-secondary hover:text-accent transition-colors" + (h.isSub ? " pl-3" : "")}
                  >
                    {h.text}
                  </a>
                ))}
              </nav>
            </div>
          </aside>
        )}

        <article class="flex-1 min-w-0">
          <BlogLayout>
            <div class="mb-8">
              <div class="flex flex-wrap items-center gap-3 text-xs text-text-secondary mb-4">
                <time datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date)}
                </time>
                {post.data.updatedDate && (
                  <span class="italic">Updated {formatDate(post.data.updatedDate)}</span>
                )}
                <span>{readingTime(post.body)} min read</span>
              </div>

              <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text-primary leading-tight mb-4">
                {post.data.title}
              </h1>

              <p class="text-lg text-text-secondary leading-relaxed mb-6">
                {post.data.description}
              </p>

              <div class="flex flex-wrap gap-2 mb-6">
                {post.data.tags.map((tag: string) => (
                  <a href={tagUrl(tag)}>
                    <Tag>{tag}</Tag>
                  </a>
                ))}
              </div>
            </div>

            <div class="border-t border-border pt-8">
              <Content />
            </div>
          </BlogLayout>

          {allSeriesPosts.length > 0 && (
            <div class="mt-12 p-6 bg-bg-secondary border border-border rounded-xl">
              <h3 class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-3">
                Series: {post.data.series}
              </h3>
              <ul class="space-y-2">
                {allSeriesPosts.map((p) => (
                    <li>
                      <a
                        href={"/blog/" + p.id}
                        class={"text-sm flex items-center gap-2 " + (p.id === post.id ? "text-accent font-medium" : "text-text-secondary hover:text-accent") + " transition-colors"}
                      >
                        <span class="w-5 h-5 flex items-center justify-center rounded-full bg-bg-tertiary text-xs">
                          {p.data.seriesOrder ?? "-"}
                        </span>
                        {p.data.title}
                        {p.id === post.id && (
                          <span class="text-xs text-accent-muted">(current)</span>
                        )}
                      </a>
                    </li>
                  ))}
              </ul>
            </div>
          )}

          {relatedPosts.length > 0 && (
            <div class="mt-12">
              <h3 class="text-lg font-semibold text-text-primary mb-6">Related Posts</h3>
              <div class="grid md:grid-cols-3 gap-4">
                {relatedPosts.map((rp) => (
                  <a
                    href={"/blog/" + rp.id}
                    class="block bg-bg-secondary border border-border rounded-xl p-5 hover:border-accent/30 transition-all duration-200 card-glow"
                  >
                    <div class="flex flex-wrap gap-1.5 mb-2">
                      {rp.data.tags.slice(0, 2).map((t: string) => (
                        <span class="text-xs text-accent">{t}</span>
                      ))}
                    </div>
                    <h4 class="text-sm font-medium text-text-primary mb-1">
                      {rp.data.title}
                    </h4>
                    <p class="text-xs text-text-secondary">{formatDate(rp.data.date)}</p>
                  </a>
                ))}
              </div>
            </div>
          )}

          <div class="mt-12 flex items-center justify-between gap-4 pt-8 border-t border-border">
            <div>
              {prevPost && (
                <a
                  href={"/blog/" + prevPost.id}
                  class="text-sm text-text-secondary hover:text-accent transition-colors"
                >
                  ← {prevPost.data.title}
                </a>
              )}
            </div>
            <div class="flex items-center gap-3">
              <span class="text-xs text-text-secondary">Share:</span>
              <a
                href={twitterShareUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-text-secondary hover:text-accent transition-colors"
              >
                Twitter
              </a>
              <a
                href={linkedinShareUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-text-secondary hover:text-accent transition-colors"
              >
                LinkedIn
              </a>
            </div>
            <div>
              {nextPost && (
                <a
                  href={"/blog/" + nextPost.id}
                  class="text-sm text-text-secondary hover:text-accent transition-colors"
                >
                  {nextPost.data.title} →
                </a>
              )}
            </div>
          </div>
        </article>
      </div>
    </div>
  </div>
</BaseLayout>
