---
import { ArrowLeft } from "lucide-react";
import { getCollection } from "astro:content";
import { Tag } from "../../../components/atoms/Tag.tsx";
import Section from "../../../components/molecules/Section.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const slugifyTag = (t: string) => t.replace(/\//g, "~");

  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const allTags = [...new Set(posts.flatMap((p) => p.data.tags))];

  return allTags.map((tag) => ({
    params: { tag: slugifyTag(tag) },
    props: { actualTag: tag },
  }));
}

const { actualTag } = Astro.props;

function slugifyTag(t: string): string {
  return t.replace(/\//g, "~");
}

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts
  .filter((p) => p.data.tags.includes(actualTag))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}

function readingTime(body: string): number {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}
---

<BaseLayout
  title={"Blog: " + actualTag + " — Abdul Majid Ridwan Tyastonoatmaja"}
  description={'Posts tagged with "' + actualTag + '"'}
  canonicalUrl={"https://abdulmajidr708.dev/blog/tag/" + slugifyTag(actualTag)}
>
  <Section title={'Posts tagged: "' + actualTag + '"'} subtitle={posts.length + " post" + (posts.length !== 1 ? "s" : "")}>
    <div class="mb-8" data-reveal>
      <a href="/blog" class="inline-flex items-center gap-1.5 text-sm text-text-secondary hover:text-brand transition-colors">
        <ArrowLeft class="w-4 h-4" aria-hidden="true" /> Back to all posts
      </a>
    </div>

    <div class="grid md:grid-cols-2 gap-6" data-reveal>
      {posts.map((post) => (
        <a
          href={"/blog/" + post.id}
          class="group bg-bg-secondary border border-border rounded-xl overflow-hidden hover:border-brand/30 hover:-translate-y-0.5 transition-all duration-200"
        >
          {post.data.image && (
            <div class="overflow-hidden">
              <img
                src={post.data.image}
                alt={post.data.imageAlt ?? post.data.title}
                class="w-full h-48 object-cover group-hover:scale-[1.02] transition-transform duration-500"
                loading="lazy"
              />
            </div>
          )}
          <div class="p-6">
            <div class="flex flex-wrap items-center gap-3 text-xs text-text-secondary mb-3">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <span>{readingTime(post.body)} min read</span>
            </div>
            <h2 class="text-lg font-semibold text-text-primary group-hover:text-brand transition-colors duration-200 mb-2">
              {post.data.title}
            </h2>
            <p class="text-text-secondary text-sm leading-relaxed mb-4 line-clamp-2">{post.data.description}</p>
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((t: string) => (
                <Tag variant="outline">{t}</Tag>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-16" data-reveal>
        <p class="text-text-secondary text-lg">No posts found with this tag.</p>
      </div>
    )}
  </Section>
</BaseLayout>
