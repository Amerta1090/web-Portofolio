---
import { getCollection } from "astro:content";
import { Rss } from "lucide-react";
import { Tag } from "../../components/atoms/Tag.tsx";
import Section from "../../components/molecules/Section.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();

const [featured, ...rest] = posts;

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
}

function readingTime(body: string): number {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}
---

<BaseLayout title="Blog — Abdul Majid Ridwan Tyastonoatmaja" description="Technical writing on ML, IoT, MLOps, and full-stack development." canonicalUrl="https://abdulmajidr708.dev/blog">
  <Section title="Blog" subtitle="Technical writing on ML, IoT, MLOps, and full-stack development.">
    <div class="flex flex-wrap items-center justify-between gap-4 mb-8" data-reveal>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1.5 text-sm rounded-full bg-brand text-bg-primary font-medium">
          All Posts
        </span>
        {allTags.map((tag: string) => (
          <a
            href={"/blog/tag/" + tag.replace(/\//g, "~")}
            class="px-3 py-1.5 text-sm rounded-full bg-bg-tertiary text-text-secondary hover:bg-bg-secondary hover:text-brand transition-all duration-200"
          >
            {tag}
          </a>
        ))}
      </div>
      <a
        href="/rss.xml"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-sm text-text-secondary hover:text-brand transition-colors"
        aria-label="RSS Feed"
      >
        <Rss class="w-4 h-4" aria-hidden="true" />
        RSS
      </a>
    </div>

    {posts.length > 0 ? (
      <>
        {featured && (
          <a
            href={"/blog/" + featured.id}
            class="group block bg-bg-secondary border border-border rounded-xl overflow-hidden hover:border-brand/30 transition-all duration-200 mb-10"
            data-reveal
          >
            <div class="grid md:grid-cols-2 gap-0">
              {featured.data.image && (
                <div class="overflow-hidden">
                  <img
                    src={featured.data.image}
                    alt={featured.data.imageAlt ?? featured.data.title}
                    class="w-full h-full object-cover min-h-[280px] group-hover:scale-[1.02] transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-8 flex flex-col justify-center">
                <div class="flex items-center gap-2 mb-4">
                  <span class="text-xs font-medium text-brand uppercase tracking-wider">Featured</span>
                  <span class="w-px h-3 bg-border" />
                  <span class="flex items-center gap-3 text-xs text-text-secondary">
                    <time datetime={featured.data.date.toISOString()}>
                      {formatDate(featured.data.date)}
                    </time>
                    <span>{readingTime(featured.body)} min read</span>
                  </span>
                </div>
                <h2 class="text-2xl md:text-3xl font-bold text-text-primary group-hover:text-brand transition-colors duration-200 mb-3">
                  {featured.data.title}
                </h2>
                <p class="text-text-secondary text-sm leading-relaxed mb-5 line-clamp-3">
                  {featured.data.description}
                </p>
                <div class="flex flex-wrap gap-2">
                  {featured.data.tags.map((tag: string) => (
                    <Tag variant="outline">{tag}</Tag>
                  ))}
                </div>
              </div>
            </div>
          </a>
        )}

        <div class="grid md:grid-cols-2 gap-6" data-reveal>
          {rest.map((post) => (
            <a
              href={"/blog/" + post.id}
              class="group bg-bg-secondary border border-border rounded-xl overflow-hidden hover:border-brand/30 hover:-translate-y-0.5 transition-all duration-200"
            >
              {post.data.image && (
                <div class="overflow-hidden">
                  <img
                    src={post.data.image}
                    alt={post.data.imageAlt ?? post.data.title}
                    class="w-full h-48 object-cover group-hover:scale-[1.02] transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-6">
                <div class="flex flex-wrap items-center gap-3 text-xs text-text-secondary mb-3">
                  <time datetime={post.data.date.toISOString()}>
                    {formatDate(post.data.date)}
                  </time>
                  {post.data.updatedDate && (
                    <span class="italic">Updated {formatDate(post.data.updatedDate)}</span>
                  )}
                  <span>{readingTime(post.body)} min read</span>
                </div>
                <h2 class="text-lg font-semibold text-text-primary group-hover:text-brand transition-colors duration-200 mb-2">
                  {post.data.title}
                </h2>
                <p class="text-text-secondary text-sm leading-relaxed mb-4 line-clamp-2">
                  {post.data.description}
                </p>
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.map((tag: string) => (
                    <Tag variant="outline">{tag}</Tag>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      </>
    ) : (
      <div class="text-center py-16" data-reveal>
        <p class="text-text-secondary text-lg">No posts yet. Check back soon.</p>
      </div>
    )}
  </Section>
</BaseLayout>
