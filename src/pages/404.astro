---
import Button from "../components/ui/Button.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Page Not Found | Abdul Majid Ridwan Tyastonoatmaja" description="The page you're looking for doesn't exist.">
  <div class="min-h-[70vh] flex flex-col items-center justify-center text-center px-4">
    <div class="text-8xl md:text-9xl font-bold text-accent/20 select-none">404</div>
    <h1 class="text-3xl md:text-4xl font-bold text-text-primary mt-4">Page Not Found</h1>
    <p class="text-text-secondary mt-3 max-w-md text-lg">
      This page doesn't exist or has been moved.
    </p>
    <div class="mt-8 flex flex-wrap gap-4 justify-center">
      <Button href="/" variant="primary" size="lg">Back to Home</Button>
      <Button href="/projects" variant="secondary" size="lg">View Projects</Button>
    </div>
  </div>
</BaseLayout>
