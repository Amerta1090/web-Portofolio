---
import Container from "../components/atoms/Container.astro";
import DataFreshness from "../components/atoms/DataFreshness.astro";
import { Tag } from "../components/atoms/Tag.tsx";
import Section from "../components/molecules/Section.astro";
import CommitHeatmap from "../islands/CommitHeatmap";
import LanguageDonut from "../islands/LanguageDonut";
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchAllGitHubData } from "../lib/github";
import type { GitHubData } from "../types/github";

const data: GitHubData | null = await fetchAllGitHubData();
const buildTime = new Date().toISOString();
---

<BaseLayout title="GitHub — Abdul Majid Ridwan Tyastonoatmaja" description="GitHub repositories, contributions, and activity.">
  {
    !data || data.pinned_repos.length === 0 ? (
      <Section title="GitHub" ariaLabel="GitHub showcase">
        <Container>
          <div class="text-center py-16">
            <p class="text-text-secondary text-lg mb-4">GitHub data will appear here after the next build.</p>
            <p class="text-text-secondary text-sm">Make sure <code class="font-mono px-2 py-0.5 bg-bg-tertiary rounded">GITHUB_TOKEN</code> is set and run the build again.</p>
          </div>
        </Container>
      </Section>
    ) : (
      <>
        <Section title="GitHub Overview" ariaLabel="GitHub overview">
          <Container>
            <div class="flex items-center justify-between mb-6">
              <p class="text-text-secondary text-sm">Aggregated stats from all public repositories</p>
              <DataFreshness fetchedAt={buildTime} label="Built" />
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
              <div class="bg-bg-secondary border border-border rounded-xl p-6 text-center">
                <p class="text-3xl font-bold text-text-primary">{data.total_repos}</p>
                <p class="text-sm text-text-secondary mt-1">Repositories</p>
              </div>
              <div class="bg-bg-secondary border border-border rounded-xl p-6 text-center">
                <p class="text-3xl font-bold text-brand">{data.total_stars}</p>
                <p class="text-sm text-text-secondary mt-1">Total Stars</p>
              </div>
              <div class="bg-bg-secondary border border-border rounded-xl p-6 text-center">
                <p class="text-3xl font-bold text-text-primary">{data.total_forks}</p>
                <p class="text-sm text-text-secondary mt-1">Total Forks</p>
              </div>
              <div class="bg-bg-secondary border border-border rounded-xl p-6 text-center">
                <p class="text-3xl font-bold text-brand">{data.contribution_count}</p>
                <p class="text-sm text-text-secondary mt-1">Contributions</p>
              </div>
            </div>
          </Container>
        </Section>

        <Section title="Pinned Repositories" variant="alt" ariaLabel="Pinned repositories">
          <Container>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
              {
                data.pinned_repos.map((repo) => (
                  <a
                    href={repo.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block bg-bg-secondary border border-border rounded-xl p-5 hover:border-brand/30 hover:-translate-y-0.5 transition-all duration-200"
                  >
                    <div class="flex items-center gap-2 mb-3">
                      <svg class="w-5 h-5 text-text-secondary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                        <path d="M9 18c-4.51 2-5-2-7-2" />
                      </svg>
                      <h3 class="font-semibold text-text-primary truncate">{repo.name}</h3>
                    </div>
                    <p class="text-sm text-text-secondary line-clamp-2 mb-4 min-h-[2.5rem]">
                      {repo.description ?? "No description"}
                    </p>
                    <div class="flex items-center gap-4 text-xs text-text-secondary">
                      {repo.language && (
                        <span class="flex items-center gap-1.5">
                          <span class="w-2.5 h-2.5 rounded-full bg-brand" />
                          {repo.language}
                        </span>
                      )}
                      <span class="flex items-center gap-1">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
                        {repo.stars}
                      </span>
                      <span class="flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" /></svg>
                        {repo.forks}
                      </span>
                    </div>
                    <div class="flex flex-wrap gap-1.5 mt-3">
                      {repo.topics.slice(0, 3).map((topic) => (
                        <Tag>{topic}</Tag>
                      ))}
                      {repo.topics.length > 3 && <Tag>+{repo.topics.length - 3}</Tag>}
                    </div>
                  </a>
                ))
              }
            </div>
          </Container>
        </Section>

        <Section title="Languages" subtitle="Hover for details" ariaLabel="Languages breakdown">
          <Container>
            <div class="bg-bg-secondary border border-border rounded-xl p-6">
              <LanguageDonut client:load languages={data.languages} />
            </div>
          </Container>
        </Section>

        <Section title="Commit Activity" subtitle="Weekly commit intensity (last 12 weeks)" variant="alt" ariaLabel="Commit activity">
          <Container>
            <div class="bg-bg-secondary border border-border rounded-xl p-6">
              <CommitHeatmap client:load data={data.commit_activity} />
            </div>
          </Container>
        </Section>

        {data.top_repos.length > 0 && (
          <Section title="Top Repositories by Stars" ariaLabel="Top repositories">
            <Container>
              <div class="bg-bg-secondary border border-border rounded-xl p-6">
                <div class="space-y-3">
                  {data.top_repos.map((repo, i) => {
                    const maxStars = data.top_repos[0]?.stars ?? 1;
                    const barWidth = Math.max((repo.stars / maxStars) * 100, 2);
                    return (
                      <a
                        href={repo.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-center gap-4 group hover:bg-bg-tertiary rounded-lg px-3 py-2 transition-colors"
                      >
                        <span class="text-sm text-text-secondary w-6 shrink-0 text-right">{i + 1}</span>
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center justify-between gap-2 mb-1">
                            <span class="text-sm font-medium text-text-primary truncate group-hover:text-brand transition-colors">{repo.name}</span>
                            <span class="text-sm text-text-secondary shrink-0 flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
                              {repo.stars}
                            </span>
                          </div>
                          <div class="h-1.5 bg-bg-tertiary rounded-full overflow-hidden">
                            <div
                              class="h-full bg-brand rounded-full transition-all duration-500"
                              style={`width: ${barWidth}%`}
                            />
                          </div>
                        </div>
                      </a>
                    );
                  })}
                </div>
              </div>
            </Container>
          </Section>
        )}

        {data.repo_activity.length > 0 && (
          <Section title="Repository Activity" subtitle="Recent commits on key repositories" variant="alt" ariaLabel="Repository activity">
            <Container>
              <div class="space-y-6">
                {
                  data.repo_activity.map((repo) => (
                    <div class="bg-bg-secondary border border-border rounded-xl p-5">
                      <a
                        href={repo.repo_url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm font-semibold text-text-primary hover:text-brand transition-colors mb-3 inline-block"
                      >
                        {repo.repo_name}
                      </a>
                      {repo.commits.length > 0 ? (
                        <ul class="space-y-2 mt-3">
                          {repo.commits.map((commit) => (
                            <li>
                              <a
                                href={commit.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="flex items-start gap-2 text-sm text-text-secondary hover:text-brand transition-colors group"
                              >
                                <svg class="w-4 h-4 mt-0.5 shrink-0 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
                                </svg>
                                <span class="group-hover:text-text-primary transition-colors line-clamp-1">{commit.message}</span>
                              </a>
                            </li>
                          ))}
                        </ul>
                      ) : (
                        <p class="text-xs text-text-secondary mt-2">No recent commits</p>
                      )}
                    </div>
                  ))
                }
              </div>
            </Container>
          </Section>
        )}

        <Section title="Contribution Graph" ariaLabel="Contribution graph">
          <Container>
            <div class="bg-bg-secondary border border-border rounded-xl p-6 overflow-x-auto">
              <p class="text-sm text-text-secondary mb-4">
                {data.contribution_count} contributions in the last year
              </p>
              <div class="flex gap-0.5">
                <div class="flex flex-col gap-0.5 pr-1 pt-2">
                  {["", "Mon", "", "Wed", "", "Fri", ""].map((day) => (
                    <div class="h-3 text-[10px] text-text-secondary leading-3">{day}</div>
                  ))}
                </div>
                <div class="flex gap-0.5" style={`width: ${data.contributions.weeks.length * 14}px`}>
                  {data.contributions.weeks.map((week) => (
                    <div class="flex flex-col gap-0.5">
                      {week.days.map((day) => (
                        <div
                          class="h-3 w-3 rounded-[2px]"
                                          title={`${day.count} contributions on ${day.date}`}
                          style={`background-color: ${day.count === 0 ? 'var(--bg-tertiary)' : day.count <= 3 ? 'rgba(122,140,111,0.4)' : day.count <= 6 ? 'rgba(122,140,111,0.6)' : day.count <= 9 ? 'rgba(122,140,111,0.8)' : '#7A8C6F'}`}
                        />
                      ))}
                    </div>
                  ))}
                </div>
              </div>
              <div class="flex items-center justify-end gap-1 mt-3">
                <span class="text-[10px] text-text-secondary">Less</span>
                {[0, 1, 2, 3, 4].map((level) => (
                  <div
                    class="w-3 h-3 rounded-[2px]"
                    style={`background-color: ${level === 0 ? 'var(--bg-tertiary)' : level === 1 ? 'rgba(122,140,111,0.4)' : level === 2 ? 'rgba(122,140,111,0.6)' : level === 3 ? 'rgba(122,140,111,0.8)' : '#7A8C6F'}`}
                  />
                ))}
                <span class="text-[10px] text-text-secondary">More</span>
              </div>
            </div>
          </Container>
        </Section>
      </>
    )
  }
</BaseLayout>
