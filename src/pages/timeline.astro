---
import Container from "../components/atoms/Container.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getTimeline } from "../lib/data";

const timelineItems = getTimeline();
const years = [...new Set(timelineItems.map((item) => item.year))].sort((a, b) => b - a);
---

<BaseLayout title="Timeline — Abdul Majid Ridwan Tyastonoatmaja" description="Technical timeline covering experience, education, and certifications." canonicalUrl="https://abdulmajidr708.dev/timeline">
  <div class="pt-24 pb-16">
    <Container>
      <header class="mb-12">
        <h1 class="text-3xl md:text-5xl font-bold text-text-primary mb-3">Timeline</h1>
        <p class="text-text-secondary text-lg">Experience, education, and certifications through the years.</p>
      </header>

      <div class="flex gap-8 lg:gap-12">
        <nav class="hidden md:flex flex-col gap-2 sticky top-28 self-start flex-shrink-0" aria-label="Year navigation">
          <span class="text-xs font-semibold text-text-secondary mb-2">Jump to year</span>
          {
            years.map((year) => (
              <a href={`#year-${year}`} class="px-3 py-1.5 text-sm text-text-secondary hover:text-text-primary hover:bg-bg-tertiary rounded-lg transition-all duration-200">
                {year}
              </a>
            ))
          }
        </nav>

        <div class="flex-1 min-w-0">
          <div class="relative">
            <div class="absolute left-[7px] top-2 bottom-2 w-0.5 bg-border hidden md:block" />

            <div class="space-y-16">
              {
                years.map((year) => {
                  const yearItems = timelineItems.filter((item) => item.year === year);
                  return (
                    <section id={`year-${year}`} class="relative pl-0 md:pl-8">
                      <div class="flex items-center gap-4 mb-6 md:absolute md:-left-1 md:top-0">
                        <div class="hidden md:flex w-4 h-4 rounded-full bg-accent border-2 border-bg-primary flex-shrink-0 z-10" />
                        <h2 class="text-2xl md:text-3xl font-bold text-text-primary">{year}</h2>
                        <span class="text-sm text-text-secondary">{yearItems.length} event{yearItems.length !== 1 ? "s" : ""}</span>
                      </div>

                      <div class="space-y-6 mt-4 md:mt-0">
                        {
                          yearItems.map((item) => (
                            <article class="bg-bg-secondary border border-border rounded-xl p-5 hover:border-accent/30 transition-all duration-200">
                              <div class="flex items-start justify-between gap-3 mb-3">
                                <div class="flex-1 min-w-0">
                                  <h3 class="text-base font-semibold text-text-primary">{item.title}</h3>
                                  <p class="text-sm text-accent mt-0.5">{item.subtitle}</p>
                                </div>
                                <div class="flex items-center gap-2 flex-shrink-0">
                                  <span class="text-xs text-text-secondary whitespace-nowrap">{item.date}</span>
                                  <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full capitalize
                                    {item.type === 'work' ? 'bg-accent/10 text-accent' : ''}
                                    {item.type === 'internship' ? 'bg-blue-500/10 text-blue-400' : ''}
                                    {item.type === 'certification' ? 'bg-green-500/10 text-green-400' : ''}
                                  ">
                                    {item.type === "work" ? "Work" : item.type === "internship" ? "Internship" : "Cert"}
                                  </span>
                                </div>
                              </div>

                              {item.highlights.length > 0 && (
                                <ul class="space-y-1.5 mb-3">
                                  {item.highlights.map((h) => (
                                    <li class="text-sm text-text-secondary flex gap-2">
                                      <span class="text-accent mt-1.5 flex-shrink-0 w-1.5 h-1.5 rounded-full bg-accent/60" />
                                      <span>{h}</span>
                                    </li>
                                  ))}
                                </ul>
                              )}

                              {item.tags.length > 0 && (
                                <div class="flex flex-wrap gap-1.5">
                                  {item.tags.map((tag) => (
                                    <span class="inline-flex items-center px-2 py-0.5 text-xs bg-bg-tertiary text-text-secondary rounded-md">{tag}</span>
                                  ))}
                                </div>
                              )}

                              {item.url && (
                                <a href={item.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 mt-3 text-xs text-accent hover:underline">
                                  View details →
                                </a>
                              )}
                            </article>
                          ))
                        }
                      </div>
                    </section>
                  );
                })
              }
            </div>
          </div>
        </div>
      </div>
    </Container>
  </div>

  <script is:inline>
    document.querySelectorAll('nav a[href^="#year-"]').forEach((link) => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const target = document.querySelector(link.getAttribute("href") || "");
        if (target) {
          target.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });
  </script>
</BaseLayout>
